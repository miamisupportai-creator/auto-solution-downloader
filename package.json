{
  "name": "auto-solution-downloader",
  "version": "1.1.0",
  "description": "Auto-download n8n solutions from GitHub — zero dependencies",
  "main": "auto-solution-downloader.js",
  "type": "module",
  "scripts": {
    "start":       "node auto-solution-downloader.js",
    "test":        "node auto-solution-downloader.js test_client",
    "test:zoho":   "node --env-file=.env test-zoho-connection.js",
    "score:leads": "node --env-file=.env lead-scoring/score-live-leads.js",
    "score:dry":   "node --env-file=.env lead-scoring/score-live-leads.js --dry-run",
    "pipeline":    "node --env-file=.env agent-runner.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "dotenv": "^16.4.5",
    "node-fetch": "^3.3.2"
  }
}
