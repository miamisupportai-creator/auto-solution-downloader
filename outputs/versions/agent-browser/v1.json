{
  "name": "agent-browser CI/CD Automation",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": [
          {
            "mode": "everyDay",
            "hour": 0,
            "minute": 0
          }
        ]
      },
      "id": "trigger_schedule",
      "name": "Trigger - Daily Schedule",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/actions/workflows/ci.yml/dispatches",
        "authentication": "genericCredentialType",
        "genericCredentialType": {
          "credentialType": "httpHeaderAuth",
          "authentication": "predefinedCredentialType"
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            },
            {
              "name": "X-GitHub-Api-Version",
              "value": "2022-11-28"
            }
          ]
        },
        "sendBody": true,
        "body": {
          "ref": "main"
        }
      },
      "id": "trigger_ci_workflow",
      "name": "Trigger GitHub CI Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        250,
        0
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "github_token_auth",
          "name": "GitHub Token Auth"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/actions/workflows/release.yml/dispatches",
        "authentication": "genericCredentialType",
        "genericCredentialType": {
          "credentialType": "httpHeaderAuth",
          "authentication": "predefinedCredentialType"
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            },
            {
              "name": "X-GitHub-Api-Version",
              "value": "2022-11-28"
            }
          ]
        },
        "sendBody": true,
        "body": {
          "ref": "main"
        }
      },
      "id": "trigger_release_workflow",
      "name": "Trigger GitHub Release Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        500,
        0
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "github_token_auth",
          "name": "GitHub Token Auth"
        }
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/releases/latest",
        "authentication": "genericCredentialType",
        "genericCredentialType": {
          "credentialType": "httpHeaderAuth",
          "authentication": "predefinedCredentialType"
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            },
            {
              "name": "X-GitHub-Api-Version",
              "value": "2022-11-28"
            }
          ]
        }
      },
      "id": "check_latest_release",
      "name": "Check Latest GitHub Release",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        750,
        0
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "github_token_auth",
          "name": "GitHub Token Auth"
        }
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://registry.npmjs.org/agent-browser",
        "authentication": "none"
      },
      "id": "check_npm_version",
      "name": "Check NPM Package Version",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1000,
        0
      ]
    },
    {
      "parameters": {
        "functionCode": "const latestTag = $input.first().json?.tag_name?.replace('v', '') || '0.0.0';\nconst npmVersion = $input.first().json?.['dist-tags']?.latest || '0.0.0';\n\nreturn {\n  github_version: latestTag,\n  npm_version: npmVersion,\n  version_match: latestTag === npmVersion,\n  needs_release: latestTag !== npmVersion\n};"
      },
      "id": "compare_versions",
      "name": "Compare Versions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1250,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ $json.needs_release }}",
              "operation": "equals",
              "value2": true
            }
          ]
        }
      },
      "id": "version_mismatch_check",
      "name": "Version Mismatch Check",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1500,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/actions/workflows/release.yml/dispatches",
        "authentication": "genericCredentialType",
        "genericCredentialType": {
          "credentialType": "httpHeaderAuth",
          "authentication": "predefinedCredentialType"
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            },
            {
              "name": "X-GitHub-Api-Version",
              "value": "2022-11-28"
            }
          ]
        },
        "sendBody": true,
        "body": {
          "ref": "main"
        }
      },
      "id": "trigger_release_on_mismatch",
      "name": "Trigger Release on Version Mismatch",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1750,
        0
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "github_token_auth",
          "name": "GitHub Token Auth"
        }
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/actions/runs?status=failure&limit=10",
        "authentication": "genericCredentialType",
        "genericCredentialType": {
          "credentialType": "httpHeaderAuth",
          "authentication": "predefinedCredentialType"
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            },
            {
              "name": "X-GitHub-Api-Version",
              "value": "2022-11-28"
            }
          ]
        }
      },
      "id": "check_failed_workflows",
      "name": "Check Failed Workflows",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        0,
        200
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "github_token_auth",
          "name": "GitHub Token Auth"
        }
      }
    },
    {
      "parameters": {
        "functionCode": "const runs = $input.first().json?.workflow_runs || [];\n\nif (runs.length === 0) {\n  return { has_failures: false, failure_count: 0 };\n}\n\nconst failures = runs.filter(r => r.status === 'completed' && r.conclusion === 'failure');\n\nreturn {\n  has_failures: failures.length > 0,\n  failure_count: failures.length,\n  recent_failures: failures.slice(0, 3).map(f => ({\n    name: f.name,\n    run_id: f.id,\n    url: f.html_url,\n    created_at: f.created_at\n  }))\n};"
      },
      "id": "analyze_failures",
      "name": "Analyze Failed Workflows",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        250,
        200
      ]
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ $json.has_failures }}",
              "operation": "equals",
              "value2": true
            }
          ]
        }
      },
      "id": "failure_notification_check",
      "name": "Failure Notification Check",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        500,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{ $env.SLACK_WEBHOOK_URL }}",
        "authentication": "none",
        "sendBody": true,
        "body": {
          "text": "⚠️ agent-browser CI Failures Detected",
          "blocks": [
            {
              "type": "section",
              "text": {
                "type": "mrkdwn",
                "text": "*agent-browser CI/CD Alert*\n\n{{ $json.failure_count }} workflow run(s) failed in the last 24 hours.\n\n{{ $json.recent_failures.map(f => `• <${f.url}|${f.name}> (${f.created_at})`).join('\\n') }}"
              }
            }
          ]
        }
      },
      "id": "send_failure_notification",
      "name": "Send Failure Notification",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        750,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://registry.npmjs.org/agent-browser",
        "authentication": "none",
        "sendBody": true,
        "body": {}
      },
      "id": "verify_npm_availability",
      "name": "Verify NPM Package Availability",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1000,
        200
      ]
    },
    {
      "parameters": {
        "operation": "update"
      },
      "id": "set_success_status",
      "name": "Set Success Status",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1250,
        200
      ]
    }
  ],
  "connections": {
    "trigger_schedule": {
      "main": [
        [
          {
            "node": "trigger_ci_workflow",
            "type": "main",
            "index": 0
          },
          {
            "node": "check_latest_release",
            "type": "main",
            "index": 0
          },
          {
            "node": "check_failed_workflows",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "trigger_ci_workflow": {
      "main": [
        [
          {
            "node": "trigger_release_workflow",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check_latest_release": {
      "main": [
        [
          {
            "node": "check_npm_version",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check_npm_version": {
      "main": [
        [
          {
            "node": "compare_versions",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "compare_versions": {
      "main": [
        [
          {
            "node": "version_mismatch_check",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "version_mismatch_check": {
      "main": [
        [
          {
            "node": "trigger_release_on_mismatch",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "verify_npm_availability",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check_failed_workflows": {
      "main": [
        [
          {
            "node": "analyze_failures",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "analyze_failures": {
      "main": [
        [
          {
            "node": "failure_notification_check",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "failure_notification_check": {
      "main": [
        [
          {
            "node": "send_failure_notification",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "verify_npm_availability",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "verify_npm_availability": {
      "main": [
        [
          {
            "node": "set_success_status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1",
    "errorHandler": {
      "type": "crashOnError"
    }
  },
  "staticData": null,
  "tags": [
    "ci-cd",
    "agent-browser",
    "release",
    "monitoring"
  ]
}