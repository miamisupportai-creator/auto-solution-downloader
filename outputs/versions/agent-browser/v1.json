{
  "name": "agent-browser Benchmark & Evaluation Workflow",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": {
          "item": [
            {
              "mode": "everyX",
              "value": 1,
              "unit": "week"
            }
          ]
        }
      },
      "id": "trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        50,
        250
      ]
    },
    {
      "parameters": {
        "content": "={\n  \"iterations\": 10,\n  \"warmup\": 1,\n  \"branch\": \"ctate/native-2\",\n  \"vcpus\": 8,\n  \"json\": true,\n  \"vercel_token\": $env.SANDBOX_VERCEL_TOKEN,\n  \"vercel_team_id\": $env.SANDBOX_VERCEL_TEAM_ID,\n  \"vercel_project_id\": $env.SANDBOX_VERCEL_PROJECT_ID\n}",
        "mode": "runOnceForAllItems"
      },
      "id": "config_node",
      "name": "Load Benchmark Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        250,
        250
      ]
    },
    {
      "parameters": {
        "url": "=https://api.vercel.com/v1/sandbox/create",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SANDBOX_VERCEL_TOKEN }}"
            }
          ]
        },
        "sendBody": true,
        "body": "={\n  \"teamId\": \"{{ $json.vercel_team_id }}\",\n  \"projectId\": \"{{ $json.vercel_project_id }}\",\n  \"timeout\": 1800000,\n  \"runtime\": \"node22\",\n  \"networkPolicy\": \"allow-all\",\n  \"resources\": {\n    \"vcpus\": {{ $json.vcpus }}\n  }\n}",
        "bodyContentType": "application/json"
      },
      "id": "create_sandbox",
      "name": "Create Vercel Sandbox",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        450,
        250
      ]
    },
    {
      "parameters": {
        "content": "={\n  \"sandboxId\": $json.sandboxId,\n  \"token\": $json.token,\n  \"iterations\": $parent.json.iterations,\n  \"warmup\": $parent.json.warmup,\n  \"branch\": $parent.json.branch\n}",
        "mode": "runOnceForAllItems"
      },
      "id": "extract_sandbox_info",
      "name": "Extract Sandbox Info",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        650,
        250
      ]
    },
    {
      "parameters": {
        "url": "=https://api.vercel.com/v1/sandbox/{{ $json.sandboxId }}/exec",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SANDBOX_VERCEL_TOKEN }}"
            }
          ]
        },
        "sendBody": true,
        "body": "={\n  \"command\": \"sudo dnf clean all && sudo dnf install -y nss nspr libxkbcommon atk at-spi2-atk at-spi2-core libXcomposite libXdamage libXrandr libXfixes libXcursor libXi libXtst libXScrnSaver libXext mesa-libgbm libdrm mesa-libGL mesa-libEGL cups-libs alsa-lib pango cairo gtk3 dbus-libs\"\n}",
        "bodyContentType": "application/json"
      },
      "id": "install_deps",
      "name": "Install Chromium Dependencies",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        850,
        250
      ]
    },
    {
      "parameters": {
        "url": "=https://api.vercel.com/v1/sandbox/{{ $json.sandboxId }}/exec",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SANDBOX_VERCEL_TOKEN }}"
            }
          ]
        },
        "sendBody": true,
        "body": "={\n  \"command\": \"npm install -g agent-browser && npx agent-browser install\"\n}",
        "bodyContentType": "application/json"
      },
      "id": "install_node_daemon",
      "name": "Install Node.js Daemon",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1050,
        100
      ]
    },
    {
      "parameters": {
        "url": "=https://api.vercel.com/v1/sandbox/{{ $json.sandboxId }}/exec",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SANDBOX_VERCEL_TOKEN }}"
            }
          ]
        },
        "sendBody": true,
        "body": "={\n  \"command\": \"source $HOME/.cargo/env && cd /tmp/agent-browser && cargo build --release\"\n}",
        "bodyContentType": "application/json"
      },
      "id": "build_native_daemon",
      "name": "Build Native Daemon",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1050,
        400
      ]
    },
    {
      "parameters": {
        "content": "={\n  \"nodeLatencies\": [],\n  \"nativeLatencies\": [],\n  \"nodeMetrics\": {},\n  \"nativeMetrics\": {}\n}",
        "mode": "runOnceForAllItems"
      },
      "id": "init_results",
      "name": "Initialize Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1250,
        250
      ]
    },
    {
      "parameters": {
        "url": "=https://api.vercel.com/v1/sandbox/{{ $json.sandboxId }}/exec",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SANDBOX_VERCEL_TOKEN }}"
            }
          ]
        },
        "sendBody": true,
        "body": "={\n  \"command\": \"AGENT_BROWSER_SESSION=bench-node agent-browser open about:blank && AGENT_BROWSER_SESSION=bench-node agent-browser snapshot && AGENT_BROWSER_SESSION=bench-node agent-browser screenshot && AGENT_BROWSER_SESSION=bench-node agent-browser close\"\n}",
        "bodyContentType": "application/json"
      },
      "id": "run_node_scenarios",
      "name": "Run Node.js Daemon Scenarios",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1450,
        100
      ]
    },
    {
      "parameters": {
        "url": "=https://api.vercel.com/v1/sandbox/{{ $json.sandboxId }}/exec",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SANDBOX_VERCEL_TOKEN }}"
            }
          ]
        },
        "sendBody": true,
        "body": "={\n  \"command\": \"AGENT_BROWSER_SESSION=bench-native /tmp/agent-browser/cli/target/release/agent-browser open about:blank && AGENT_BROWSER_SESSION=bench-native /tmp/agent-browser/cli/target/release/agent-browser snapshot && AGENT_BROWSER_SESSION=bench-native /tmp/agent-browser/cli/target/release/agent-browser screenshot && AGENT_BROWSER_SESSION=bench-native /tmp/agent-browser/cli/target/release/agent-browser close\"\n}",
        "bodyContentType": "application/json"
      },
      "id": "run_native_scenarios",
      "name": "Run Native Daemon Scenarios",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1450,
        400
      ]
    },
    {
      "parameters": {
        "content": "={\n  \"comparison\": {\n    \"nodeResults\": $nodes[\"run_node_scenarios\"].json,\n    \"nativeResults\": $nodes[\"run_native_scenarios\"].json,\n    \"timestamp\": new Date().toISOString(),\n    \"config\": {\n      \"iterations\": $parent.json.iterations,\n      \"warmup\": $parent.json.warmup,\n      \"branch\": $parent.json.branch,\n      \"vcpus\": $parent.json.vcpus\n    }\n  }\n}",
        "mode": "runOnceForAllItems"
      },
      "id": "compile_results",
      "name": "Compile Comparison Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1650,
        250
      ]
    },
    {
      "parameters": {
        "url": "=https://api.vercel.com/v1/sandbox/{{ $json.sandboxId }}/stop",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SANDBOX_VERCEL_TOKEN }}"
            }
          ]
        }
      },
      "id": "cleanup_sandbox",
      "name": "Stop Sandbox",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1850,
        250
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "benchmark-results",
        "responseMode": "onReceived",
        "responseData": "{\n  \"status\": \"received\",\n  \"timestamp\": \"{{ now() }}\"\n}",
        "bodyParametersJson": "={\n  \"comparison\": $json.comparison\n}"
      },
      "id": "webhook_output",
      "name": "Webhook Output",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [
        2050,
        250
      ]
    }
  ],
  "connections": {
    "trigger": {
      "main": [
        [
          {
            "node": "config_node",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "config_node": {
      "main": [
        [
          {
            "node": "create_sandbox",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "create_sandbox": {
      "main": [
        [
          {
            "node": "extract_sandbox_info",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "extract_sandbox_info": {
      "main": [
        [
          {
            "node": "install_deps",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "install_deps": {
      "main": [
        [
          {
            "node": "install_node_daemon",
            "type": "main",
            "index": 0
          },
          {
            "node": "build_native_daemon",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "install_node_daemon": {
      "main": [
        [
          {
            "node": "init_results",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "build_native_daemon": {
      "main": [
        [
          {
            "node": "init_results",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "init_results": {
      "main": [
        [
          {
            "node": "run_node_scenarios",
            "type": "main",
            "index": 0
          },
          {
            "node": "run_native_scenarios",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "run_node_scenarios": {
      "main": [
        [
          {
            "node": "compile_results",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "run_native_scenarios": {
      "main": [
        [
          {
            "node": "compile_results",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "compile_results": {
      "main": [
        [
          {
            "node": "cleanup_sandbox",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "cleanup_sandbox": {
      "main": [
        [
          {
            "node": "webhook_output",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}