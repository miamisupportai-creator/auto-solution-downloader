{
  "name": "agent-browser CI/Release Automation",
  "nodes": [
    {
      "parameters": {
        "trigger": "manually"
      },
      "id": "trigger",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/contents/package.json",
        "method": "GET",
        "authentication": "generic",
        "genericAuthType": "httpHeaderAuth"
      },
      "id": "fetch_local_version",
      "name": "Fetch Local Version",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        200,
        0
      ],
      "credentials": {
        "genericHttpHeaderAuth": "github_token"
      }
    },
    {
      "parameters": {
        "url": "https://registry.npmjs.org/agent-browser",
        "method": "GET"
      },
      "id": "fetch_npm_version",
      "name": "Fetch NPM Version",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        400,
        0
      ]
    },
    {
      "parameters": {
        "functionCode": "const packageData = JSON.parse(Buffer.from(items[0].json.content, 'base64').toString());\nconst localVersion = packageData.version;\nconst npmVersion = items[1].json['dist-tags']?.latest || '0.0.0';\nreturn [{\n  json: {\n    localVersion,\n    npmVersion,\n    shouldRelease: localVersion !== npmVersion,\n    version: localVersion\n  }\n}];"
      },
      "id": "compare_versions",
      "name": "Compare Versions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        600,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.shouldRelease }}",
              "operation": "equals",
              "value2": true
            }
          ]
        }
      },
      "id": "check_should_release",
      "name": "Should Release?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        800,
        0
      ]
    },
    {
      "parameters": {
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/releases/tags/v{{ $json.version }}",
        "method": "GET",
        "authentication": "generic",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "check_github_release",
      "name": "Check GitHub Release",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1000,
        0
      ],
      "credentials": {
        "genericHttpHeaderAuth": "github_token"
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "functionCode": "const releaseExists = items[0].json.id ? true : false;\nreturn [{\n  json: {\n    ...items[0].json,\n    releaseExists\n  }\n}];"
      },
      "id": "determine_release_status",
      "name": "Determine Release Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        0
      ]
    },
    {
      "parameters": {
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/git/refs/heads/main",
        "method": "GET",
        "authentication": "generic",
        "genericAuthType": "httpHeaderAuth"
      },
      "id": "trigger_build_workflow",
      "name": "Trigger Build Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1400,
        0
      ],
      "credentials": {
        "genericHttpHeaderAuth": "github_token"
      }
    },
    {
      "parameters": {
        "functionCode": "const commitSha = items[0].json.object?.sha;\nreturn [{\n  json: {\n    workflow: 'build-binaries',\n    ref: commitSha || 'main',\n    status: 'triggered'\n  }\n}];"
      },
      "id": "build_status",
      "name": "Build Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1600,
        0
      ]
    },
    {
      "parameters": {
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/actions/runs",
        "method": "GET",
        "authentication": "generic",
        "genericAuthType": "httpHeaderAuth",
        "qs": {
          "workflow_id": "release.yml",
          "status": "completed",
          "per_page": "1"
        }
      },
      "id": "poll_build_status",
      "name": "Poll Build Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1800,
        0
      ],
      "credentials": {
        "genericHttpHeaderAuth": "github_token"
      }
    },
    {
      "parameters": {
        "functionCode": "const builds = items[0].json.workflow_runs || [];\nconst latestBuild = builds[0];\nconst conclusion = latestBuild?.conclusion;\nconst status = latestBuild?.status;\nreturn [{\n  json: {\n    buildSuccess: conclusion === 'success',\n    buildStatus: status,\n    buildConclusion: conclusion,\n    artifactsUrl: latestBuild?.artifacts_url\n  }\n}];"
      },
      "id": "check_build_success",
      "name": "Check Build Success",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2000,
        0
      ]
    },
    {
      "parameters": {
        "url": "https://registry.npmjs.org/-/npm/v1/security/advisories",
        "method": "GET"
      },
      "id": "verify_npm_access",
      "name": "Verify NPM Access",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2200,
        0
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "functionCode": "const npmAccessible = items[0].statusCode < 400;\nreturn [{\n  json: {\n    npmAccessible,\n    readyToPublish: items[0].json.buildSuccess && npmAccessible\n  }\n}];"
      },
      "id": "publication_ready",
      "name": "Publication Ready",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2400,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.readyToPublish }}",
              "operation": "equals",
              "value2": true
            }
          ]
        }
      },
      "id": "ready_to_publish",
      "name": "Ready to Publish?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        2600,
        0
      ]
    },
    {
      "parameters": {
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/releases",
        "method": "POST",
        "authentication": "generic",
        "genericAuthType": "httpHeaderAuth",
        "body": {
          "tag_name": "v{{ $json.version }}",
          "name": "v{{ $json.version }}",
          "body": "Release version {{ $json.version }}",
          "draft": false,
          "prerelease": false
        },
        "bodyType": "json"
      },
      "id": "create_github_release",
      "name": "Create GitHub Release",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2800,
        0
      ],
      "credentials": {
        "genericHttpHeaderAuth": "github_token"
      }
    },
    {
      "parameters": {
        "functionCode": "return [{\n  json: {\n    releaseCreated: true,\n    releaseName: 'v' + items[0].json.version,\n    releaseUrl: items[0].json.html_url,\n    status: 'success'\n  }\n}];"
      },
      "id": "release_complete",
      "name": "Release Complete",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3000,
        0
      ]
    }
  ],
  "connections": {
    "trigger": {
      "main": [
        [
          {
            "node": "fetch_local_version",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetch_local_version": {
      "main": [
        [
          {
            "node": "fetch_npm_version",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetch_npm_version": {
      "main": [
        [
          {
            "node": "compare_versions",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "compare_versions": {
      "main": [
        [
          {
            "node": "check_should_release",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check_should_release": {
      "main": [
        [
          {
            "node": "check_github_release",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check_github_release": {
      "main": [
        [
          {
            "node": "determine_release_status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "determine_release_status": {
      "main": [
        [
          {
            "node": "trigger_build_workflow",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "trigger_build_workflow": {
      "main": [
        [
          {
            "node": "build_status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "build_status": {
      "main": [
        [
          {
            "node": "poll_build_status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "poll_build_status": {
      "main": [
        [
          {
            "node": "check_build_success",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check_build_success": {
      "main": [
        [
          {
            "node": "verify_npm_access",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "verify_npm_access": {
      "main": [
        [
          {
            "node": "publication_ready",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "publication_ready": {
      "main": [
        [
          {
            "node": "ready_to_publish",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "ready_to_publish": {
      "main": [
        [
          {
            "node": "create_github_release",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "create_github_release": {
      "main": [
        [
          {
            "node": "release_complete",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}