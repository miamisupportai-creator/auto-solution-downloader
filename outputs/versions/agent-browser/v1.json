{
  "name": "agent-browser CI/CD Automation",
  "nodes": [
    {
      "parameters": {
        "trigger": "on_webhook_request"
      },
      "id": "webhook-trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://registry.npmjs.org/agent-browser"
      },
      "id": "check-npm-version",
      "name": "Check NPM Version",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [450, 300]
    },
    {
      "parameters": {
        "jsCode": "const npmData = $input.all()[0].json;\nconst npmVersion = npmData['dist-tags']?.latest || '0.0.0';\nconst localVersion = process.env.LOCAL_VERSION || '1.0.0';\nreturn {\n  npmVersion,\n  localVersion,\n  shouldRelease: npmVersion !== localVersion,\n  needsGithubRelease: true\n};"
      },
      "id": "compare-versions",
      "name": "Compare Versions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 300]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "value1": "{{ $node[\"compare-versions\"].json.shouldRelease }}",
              "condition": "equal",
              "value2": true
            }
          ]
        }
      },
      "id": "should-release-check",
      "name": "Should Release?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [850, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/dispatches",
        "authentication": "genericCredentialType",
        "genericCredentialType": {
          "authentication": "httpHeaderAuth",
          "genericCredentials": "{{ $secrets.GITHUB_TOKEN }}"
        },
        "sendBody": true,
        "bodyParametersJson": "{\n  \"event_type\": \"build-release\",\n  \"client_payload\": {\n    \"version\": \"{{ $node[\\\"compare-versions\\\"].json.localVersion }}\"\n  }\n}"
      },
      "id": "trigger-build",
      "name": "Trigger Build Pipeline",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1050, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/releases",
        "authentication": "genericCredentialType",
        "genericCredentialType": {
          "authentication": "httpHeaderAuth",
          "genericCredentials": "{{ $secrets.GITHUB_TOKEN }}"
        },
        "sendBody": true,
        "bodyParametersJson": "{\n  \"tag_name\": \"v{{ $node[\\\"compare-versions\\\"].json.localVersion }}\",\n  \"name\": \"v{{ $node[\\\"compare-versions\\\"].json.localVersion }}\",\n  \"draft\": false,\n  \"prerelease\": false\n}"
      },
      "id": "create-github-release",
      "name": "Create GitHub Release",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1050, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://registry.npmjs.org/-/npm/v1/user",
        "authentication": "genericCredentialType",
        "genericCredentialType": {
          "authentication": "httpHeaderAuth",
          "genericCredentials": "{{ $secrets.NPM_TOKEN }}"
        }
      },
      "id": "publish-npm",
      "name": "Publish to NPM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1050, 550]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/actions/workflows/ci.yml/dispatches",
        "authentication": "genericCredentialType",
        "genericCredentialType": {
          "authentication": "httpHeaderAuth",
          "genericCredentials": "{{ $secrets.GITHUB_TOKEN }}"
        },
        "sendBody": true,
        "bodyParametersJson": "{\n  \"ref\": \"main\"\n}"
      },
      "id": "trigger-ci",
      "name": "Trigger CI Tests",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1250, 300]
    },
    {
      "parameters": {
        "jsCode": "return {\n  status: 'Release pipeline initiated',\n  version: $node[\"compare-versions\"].json.localVersion,\n  timestamp: new Date().toISOString()\n};"
      },
      "id": "log-completion",
      "name": "Log Completion",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1450, 300]
    }
  ],
  "connections": {
    "webhook-trigger": {
      "main": [
        [
          {
            "node": "check-npm-version",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check-npm-version": {
      "main": [
        [
          {
            "node": "compare-versions",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "compare-versions": {
      "main": [
        [
          {
            "node": "should-release-check",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "should-release-check": {
      "main": [
        [
          {
            "node": "trigger-build",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "log-completion",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "trigger-build": {
      "main": [
        [
          {
            "node": "create-github-release",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "create-github-release": {
      "main": [
        [
          {
            "node": "publish-npm",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "publish-npm": {
      "main": [
        [
          {
            "node": "trigger-ci",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "trigger-ci": {
      "main": [
        [
          {
            "node": "log-completion",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}