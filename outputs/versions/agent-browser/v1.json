{
  "name": "agent-browser Benchmark & Evaluation Workflow",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": [
          {
            "mode": "everyWeek",
            "week": "Monday",
            "hour": 2,
            "minute": 0
          }
        ]
      },
      "id": "trigger-schedule",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        50,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.vercel.com/v1/sandbox",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.SANDBOX_VERCEL_TOKEN }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "application/json",
        "body": {
          "teamId": "{{ $env.SANDBOX_VERCEL_TEAM_ID }}",
          "projectId": "{{ $env.SANDBOX_VERCEL_PROJECT_ID }}",
          "runtime": "node22",
          "resources": {
            "vcpus": 8
          }
        }
      },
      "id": "create-sandbox",
      "name": "Create Sandbox",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        250,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{ $json.sandbox.url }}/api/v1/command",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $json.sandbox.token }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "application/json",
        "body": {
          "cmd": "sh",
          "args": [
            "-c",
            "sudo dnf clean all && sudo dnf install -y --skip-broken nss nspr libxkbcommon atk at-spi2-atk at-spi2-core libXcomposite libXdamage libXrandr libXfixes libXcursor libXi libXtst libXScrnSaver libXext mesa-libgbm libdrm mesa-libGL mesa-libEGL cups-libs alsa-lib pango cairo gtk3 dbus-libs"
          ]
        }
      },
      "id": "install-chromium-deps",
      "name": "Install Chromium Dependencies",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{ $json.sandbox.url }}/api/v1/command",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $json.sandbox.token }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "application/json",
        "body": {
          "cmd": "npm",
          "args": [
            "install",
            "-g",
            "agent-browser"
          ]
        }
      },
      "id": "install-node-daemon",
      "name": "Install Node.js Daemon",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        650,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{ $json.sandbox.url }}/api/v1/command",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $json.sandbox.token }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "application/json",
        "body": {
          "cmd": "npx",
          "args": [
            "agent-browser",
            "install"
          ]
        }
      },
      "id": "install-npx-agent-browser",
      "name": "Install agent-browser CLI",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        850,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{ $json.sandbox.url }}/api/v1/command",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $json.sandbox.token }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "application/json",
        "body": {
          "cmd": "sh",
          "args": [
            "-c",
            "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y"
          ]
        }
      },
      "id": "install-rust-toolchain",
      "name": "Install Rust Toolchain",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        250,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{ $json.sandbox.url }}/api/v1/command",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $json.sandbox.token }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "application/json",
        "body": {
          "cmd": "sh",
          "args": [
            "-c",
            "git clone --depth 1 --branch ctate/native-2 https://github.com/vercel-labs/agent-browser.git /tmp/agent-browser"
          ]
        }
      },
      "id": "clone-repo",
      "name": "Clone Repository",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{ $json.sandbox.url }}/api/v1/command",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $json.sandbox.token }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "application/json",
        "body": {
          "cmd": "sh",
          "args": [
            "-c",
            "source $HOME/.cargo/env && cd /tmp/agent-browser/cli && cargo build --release"
          ]
        }
      },
      "id": "build-native-daemon",
      "name": "Build Native Daemon",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        650,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{ $json.sandbox.url }}/api/v1/command",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $json.sandbox.token }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "application/json",
        "body": {
          "cmd": "sh",
          "args": [
            "-c",
            "AGENT_BROWSER_SESSION=bench-node agent-browser open about:blank"
          ]
        }
      },
      "id": "run-node-benchmark",
      "name": "Run Node.js Benchmark",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        850,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{ $json.sandbox.url }}/api/v1/command",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $json.sandbox.token }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "application/json",
        "body": {
          "cmd": "sh",
          "args": [
            "-c",
            "AGENT_BROWSER_SESSION=bench-native agent-browser open about:blank"
          ]
        }
      },
      "id": "run-native-benchmark",
      "name": "Run Native Benchmark",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1050,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{ $json.sandbox.url }}/api/v1/command",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $json.sandbox.token }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "application/json",
        "body": {
          "cmd": "sh",
          "args": [
            "-c",
            "agent-browser close"
          ]
        }
      },
      "id": "cleanup-sandbox",
      "name": "Close Browser & Cleanup",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1250,
        400
      ]
    },
    {
      "parameters": {
        "functionCode": "return {\n  timestamp: new Date().toISOString(),\n  benchmarkResults: $json,\n  node_version: $json.nodeVersion,\n  native_version: $json.nativeVersion,\n  summary: {\n    total_scenarios: 8,\n    timestamp: new Date().toISOString()\n  }\n};"
      },
      "id": "format-results",
      "name": "Format Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1450,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{ $env.RESULTS_WEBHOOK_URL }}",
        "sendBody": true,
        "contentType": "application/json",
        "body": "{{ $json }}"
      },
      "id": "send-results",
      "name": "Send Results to Webhook",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1650,
        400
      ]
    }
  ],
  "connections": {
    "trigger-schedule": {
      "main": [
        [
          {
            "node": "create-sandbox",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "create-sandbox": {
      "main": [
        [
          {
            "node": "install-chromium-deps",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "install-chromium-deps": {
      "main": [
        [
          {
            "node": "install-node-daemon",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "install-node-daemon": {
      "main": [
        [
          {
            "node": "install-npx-agent-browser",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "install-npx-agent-browser": {
      "main": [
        [
          {
            "node": "install-rust-toolchain",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "install-rust-toolchain": {
      "main": [
        [
          {
            "node": "clone-repo",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "clone-repo": {
      "main": [
        [
          {
            "node": "build-native-daemon",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "build-native-daemon": {
      "main": [
        [
          {
            "node": "run-node-benchmark",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "run-node-benchmark": {
      "main": [
        [
          {
            "node": "run-native-benchmark",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "run-native-benchmark": {
      "main": [
        [
          {
            "node": "cleanup-sandbox",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "cleanup-sandbox": {
      "main": [
        [
          {
            "node": "format-results",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "format-results": {
      "main": [
        [
          {
            "node": "send-results",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}