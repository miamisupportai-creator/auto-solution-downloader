{
  "name": "agent-browser Benchmark & Evaluation Workflow",
  "nodes": [
    {
      "parameters": {
        "trigger": "everyDay",
        "hour": 2,
        "minute": 0
      },
      "id": "Schedule_Trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.schedule",
      "typeVersion": 1,
      "position": [50, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/releases/latest",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth"
      },
      "id": "Get_Latest_Release",
      "name": "Get Latest Release",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "functionCode": "const release = $input.first().json;\nreturn {\n  version: release.tag_name.replace('v', ''),\n  assets: release.assets.map(a => ({\n    name: a.name,\n    download_url: a.browser_download_url,\n    size: a.size\n  }))\n};"
      },
      "id": "Parse_Release_Info",
      "name": "Parse Release Info",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [450, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SANDBOX_API_URL }}/create",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.SANDBOX_VERCEL_TOKEN }}"
            }
          ]
        },
        "body": {
          "parameters": {
            "teamId": "={{ $env.SANDBOX_VERCEL_TEAM_ID }}",
            "projectId": "={{ $env.SANDBOX_VERCEL_PROJECT_ID }}",
            "runtime": "node22",
            "resources": {
              "vcpus": 8
            }
          }
        }
      },
      "id": "Create_Sandbox",
      "name": "Create Sandbox",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [650, 300]
    },
    {
      "parameters": {
        "functionCode": "const sandbox = $input.first().json;\nreturn {\n  sandboxId: sandbox.id,\n  status: 'created',\n  createdAt: new Date().toISOString()\n};"
      },
      "id": "Extract_Sandbox_ID",
      "name": "Extract Sandbox ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [850, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SANDBOX_API_URL }}/{{ $node.Extract_Sandbox_ID.json.sandboxId }}/run",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.SANDBOX_VERCEL_TOKEN }}"
            }
          ]
        },
        "body": {
          "parameters": {
            "command": "sh",
            "args": [
              "-c",
              "sudo dnf install -y gcc gcc-c++ make perl-core openssl-devel nss nspr libxkbcommon atk at-spi2-atk at-spi2-core libXcomposite libXdamage libXrandr libXfixes libXcursor libXi libXtst libXScrnSaver libXext mesa-libgbm libdrm mesa-libGL mesa-libEGL cups-libs alsa-lib pango cairo gtk3 dbus-libs"
            ]
          }
        }
      },
      "id": "Install_Dependencies",
      "name": "Install Dependencies",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1050, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SANDBOX_API_URL }}/{{ $node.Extract_Sandbox_ID.json.sandboxId }}/run",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.SANDBOX_VERCEL_TOKEN }}"
            }
          ]
        },
        "body": {
          "parameters": {
            "command": "npm",
            "args": [
              "install",
              "-g",
              "agent-browser"
            ]
          }
        }
      },
      "id": "Install_Node_Daemon",
      "name": "Install Node Daemon",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1250, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SANDBOX_API_URL }}/{{ $node.Extract_Sandbox_ID.json.sandboxId }}/run",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.SANDBOX_VERCEL_TOKEN }}"
            }
          ]
        },
        "body": {
          "parameters": {
            "command": "sh",
            "args": [
              "-c",
              "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y && source $HOME/.cargo/env && git clone --depth 1 --branch main https://github.com/vercel-labs/agent-browser.git /tmp/agent-browser && cd /tmp/agent-browser/cli && cargo build --release"
            ]
          }
        }
      },
      "id": "Build_Native_Daemon",
      "name": "Build Native Daemon",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1250, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SANDBOX_API_URL }}/{{ $node.Extract_Sandbox_ID.json.sandboxId }}/run",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.SANDBOX_VERCEL_TOKEN }}"
            }
          ]
        },
        "body": {
          "parameters": {
            "command": "sh",
            "args": [
              "-c",
              "export AGENT_BROWSER_SESSION=bench-node && agent-browser open about:blank && agent-browser snapshot && agent-browser screenshot && agent-browser eval 'document.title' && agent-browser close"
            ]
          }
        }
      },
      "id": "Run_Node_Benchmark",
      "name": "Run Node Benchmark",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1450, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SANDBOX_API_URL }}/{{ $node.Extract_Sandbox_ID.json.sandboxId }}/run",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.SANDBOX_VERCEL_TOKEN }}"
            }
          ]
        },
        "body": {
          "parameters": {
            "command": "sh",
            "args": [
              "-c",
              "export AGENT_BROWSER_SESSION=bench-native && agent-browser open about:blank && agent-browser snapshot && agent-browser screenshot && agent-browser eval 'document.title' && agent-browser close"
            ]
          }
        }
      },
      "id": "Run_Native_Benchmark",
      "name": "Run Native Benchmark",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1450, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SANDBOX_API_URL }}/{{ $node.Extract_Sandbox_ID.json.sandboxId }}/stop",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.SANDBOX_VERCEL_TOKEN }}"
            }
          ]
        }
      },
      "id": "Cleanup_Sandbox",
      "name": "Cleanup Sandbox",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1650, 300]
    },
    {
      "parameters": {
        "functionCode": "const nodeResult = $node.Run_Node_Benchmark.json;\nconst nativeResult = $node.Run_Native_Benchmark.json;\nconst release = $node.Parse_Release_Info.json;\n\nreturn {\n  benchmark_results: {\n    version: release.version,\n    timestamp: new Date().toISOString(),\n    node_daemon: nodeResult,\n    native_daemon: nativeResult,\n    comparison: 'completed'\n  }\n};"
      },
      "id": "Aggregate_Results",
      "name": "Aggregate Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1800, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.RESULTS_WEBHOOK_URL }}",
        "body": {
          "parameters": "{{ $node.Aggregate_Results.json }}"
        }
      },
      "id": "Send_Results",
      "name": "Send Results",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [2000, 300]
    }
  ],
  "connections": {
    "Schedule_Trigger": {
      "main": [
        [
          {
            "node": "Get_Latest_Release",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get_Latest_Release": {
      "main": [
        [
          {
            "node": "Parse_Release_Info",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse_Release_Info": {
      "main": [
        [
          {
            "node": "Create_Sandbox",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Create_Sandbox": {
      "main": [
        [
          {
            "node": "Extract_Sandbox_ID",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Extract_Sandbox_ID": {
      "main": [
        [
          {
            "node": "Install_Dependencies",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Install_Dependencies": {
      "main": [
        [
          {
            "node": "Install_Node_Daemon",
            "type": "main",
            "index": 0
          },
          {
            "node": "Build_Native_Daemon",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Install_Node_Daemon": {
      "main": [
        [
          {
            "node": "Run_Node_Benchmark",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Build_Native_Daemon": {
      "main": [
        [
          {
            "node": "Run_Native_Benchmark",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Run_Node_Benchmark": {
      "main": [
        [
          {
            "node": "Cleanup_Sandbox",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Run_Native_Benchmark": {
      "main": [
        [
          {
            "node": "Cleanup_Sandbox",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Cleanup_Sandbox": {
      "main": [
        [
          {
            "node": "Aggregate_Results",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Aggregate_Results": {
      "main": [
        [
          {
            "node": "Send_Results",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1"
  }
}