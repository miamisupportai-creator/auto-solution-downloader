{
  "name": "Khoj Content Synchronization Workflow",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": [
          {
            "mode": "everyX",
            "value": 10,
            "unit": "minutes"
          }
        ]
      },
      "id": "schedule_trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "url": "{{ $env.KHOJ_HOST_URL || 'https://app.khoj.dev' }}/api/content?client=workflow",
        "method": "GET",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth"
      },
      "id": "get_sync_status",
      "name": "Get Sync Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const khojToken = $env.KHOJ_TOKEN;\nconst khojUrl = $env.KHOJ_HOST_URL || 'https://app.khoj.dev';\nconst fileList = $input.all();\n\nif (!khojToken) {\n  throw new Error('KHOJ_TOKEN environment variable not set');\n}\n\nreturn {\n  auth_header: `Bearer ${khojToken}`,\n  khoj_url: khojUrl,\n  files_to_sync: fileList.length > 0 ? fileList : []\n};"
      },
      "id": "prepare_auth",
      "name": "Prepare Authentication",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "url": "={{ $node.prepare_auth.json.khoj_url }}/api/v1/user",
        "method": "GET",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ $node.prepare_auth.json.auth_header }}"
            }
          ]
        }
      },
      "id": "get_user_info",
      "name": "Get User Info",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        850,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": [
            {
              "condition": "exists",
              "leftValue": "={{ $node.get_user_info.json.user_id }}",
              "rightValue": null
            }
          ]
        }
      },
      "id": "check_auth_success",
      "name": "Check Auth Success",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1050,
        300
      ]
    },
    {
      "parameters": {
        "url": "={{ $node.prepare_auth.json.khoj_url }}/api/content",
        "method": "GET",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ $node.prepare_auth.json.auth_header }}"
            }
          ]
        },
        "options": {
          "queryParameters": {
            "parameters": [
              {
                "name": "client",
                "value": "workflow"
              }
            ]
          }
        }
      },
      "id": "fetch_indexed_content",
      "name": "Fetch Indexed Content",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1250,
        150
      ]
    },
    {
      "parameters": {
        "jsCode": "const indexedContent = $node.fetch_indexed_content.json.content || [];\nconst userInfo = $node.get_user_info.json;\n\nreturn {\n  indexed_files_count: Array.isArray(indexedContent) ? indexedContent.length : 0,\n  user_email: userInfo.email,\n  user_id: userInfo.user_id,\n  last_sync: new Date().toISOString(),\n  status: 'synced'\n};"
      },
      "id": "process_sync_result",
      "name": "Process Sync Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1450,
        150
      ]
    },
    {
      "parameters": {
        "url": "={{ $env.WEBHOOK_URL || '' }}",
        "method": "POST",
        "contentType": "application/json",
        "body": "={{ JSON.stringify($node.process_sync_result.json) }}"
      },
      "id": "send_sync_notification",
      "name": "Send Sync Notification",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1650,
        150
      ]
    },
    {
      "parameters": {
        "message": "=Khoj sync completed. Files indexed: {{ $node.process_sync_result.json.indexed_files_count }}"
      },
      "id": "log_success",
      "name": "Log Success",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [
        1850,
        150
      ]
    },
    {
      "parameters": {
        "jsCode": "const error = $node.check_auth_success.context.previousNode.error || 'Authentication failed';\n\nreturn {\n  error_message: error,\n  timestamp: new Date().toISOString(),\n  status: 'failed'\n};"
      },
      "id": "handle_auth_error",
      "name": "Handle Auth Error",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1250,
        450
      ]
    },
    {
      "parameters": {
        "url": "={{ $env.WEBHOOK_URL || '' }}",
        "method": "POST",
        "contentType": "application/json",
        "body": "={{ JSON.stringify($node.handle_auth_error.json) }}"
      },
      "id": "send_error_notification",
      "name": "Send Error Notification",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1450,
        450
      ]
    },
    {
      "parameters": {
        "message": "=Khoj sync failed: {{ $node.handle_auth_error.json.error_message }}"
      },
      "id": "log_error",
      "name": "Log Error",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [
        1650,
        450
      ]
    }
  ],
  "connections": {
    "schedule_trigger": {
      "main": [
        [
          {
            "node": "get_sync_status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "get_sync_status": {
      "main": [
        [
          {
            "node": "prepare_auth",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "prepare_auth": {
      "main": [
        [
          {
            "node": "get_user_info",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "get_user_info": {
      "main": [
        [
          {
            "node": "check_auth_success",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check_auth_success": {
      "main": [
        [
          {
            "node": "fetch_indexed_content",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "handle_auth_error",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetch_indexed_content": {
      "main": [
        [
          {
            "node": "process_sync_result",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "process_sync_result": {
      "main": [
        [
          {
            "node": "send_sync_notification",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "send_sync_notification": {
      "main": [
        [
          {
            "node": "log_success",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "handle_auth_error": {
      "main": [
        [
          {
            "node": "send_error_notification",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "send_error_notification": {
      "main": [
        [
          {
            "node": "log_error",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "timezone": "UTC",
    "saveDataErrorExecution": "all",
    "saveDataSuccessExecution": "all",
    "executionTimeout": 3600,
    "maxRetries": 3
  }
}