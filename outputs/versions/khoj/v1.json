{
  "name": "Khoj Content Sync Workflow",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": [
          {
            "mode": "everyX",
            "value": 10,
            "unit": "minutes"
          }
        ]
      },
      "id": "trigger_sync",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "functionCode": "const filesToIndex = $input.all();\nreturn filesToIndex;"
      },
      "id": "collect_files",
      "name": "Collect Files to Sync",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        450,
        300
      ],
      "dependsOn": [
        "trigger_sync"
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "{{ $env.KHOJ_HOST_URL }}/api/v1/user",
        "authentication": "bearerToken",
        "nodeCredentialType": "httpHeaderAuth",
        "options": {
          "headers": {
            "Authorization": "Bearer {{ $env.KHOJ_API_TOKEN }}"
          }
        }
      },
      "id": "validate_auth",
      "name": "Validate Authentication",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        650,
        300
      ],
      "dependsOn": [
        "collect_files"
      ]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "{{ $env.KHOJ_HOST_URL }}/api/content",
        "authentication": "bearerToken",
        "sendBody": true,
        "bodyParametersUi": "keyvaluepairs",
        "bodyParameters": {
          "parameters": [
            {
              "name": "client",
              "value": "workflow"
            }
          ]
        },
        "options": {
          "headers": {
            "Authorization": "Bearer {{ $env.KHOJ_API_TOKEN }}"
          }
        }
      },
      "id": "sync_content",
      "name": "Sync Content to Khoj",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        850,
        300
      ],
      "dependsOn": [
        "validate_auth"
      ]
    },
    {
      "parameters": {
        "functionCode": "const syncResult = $input.all()[0];\nif (syncResult.statusCode === 200) {\n  return { success: true, synced_files: syncResult.data };\n} else {\n  return { success: false, error: syncResult.statusMessage };\n}"
      },
      "id": "process_result",
      "name": "Process Sync Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1050,
        300
      ],
      "dependsOn": [
        "sync_content"
      ]
    },
    {
      "parameters": {
        "errorMessage": "Sync failed: {{ $json.error }}",
        "fallbackOutput": true
      },
      "id": "error_handler",
      "name": "Error Handler",
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [
        850,
        450
      ],
      "dependsOn": [
        "sync_content"
      ]
    },
    {
      "parameters": {
        "functionCode": "const lastSync = new Date().toISOString();\nreturn { lastSync, status: 'completed' };"
      },
      "id": "update_state",
      "name": "Update Last Sync Time",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1250,
        300
      ],
      "dependsOn": [
        "process_result"
      ]
    }
  ],
  "connections": {
    "trigger_sync": {
      "main": [
        [
          {
            "node": "collect_files",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "collect_files": {
      "main": [
        [
          {
            "node": "validate_auth",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "validate_auth": {
      "main": [
        [
          {
            "node": "sync_content",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "sync_content": {
      "main": [
        [
          {
            "node": "process_result",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "process_result": {
      "main": [
        [
          {
            "node": "update_state",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "any"
  },
  "staticData": null,
  "tags": [
    "khoj",
    "sync",
    "content-indexing"
  ]
}