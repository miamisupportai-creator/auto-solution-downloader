{
  "name": "Dify LLM Application Platform",
  "nodes": [
    {
      "parameters": {
        "triggerTopic": "dify_workflow_trigger"
      },
      "id": "webhook_trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhookTrigger",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "url": "=http://localhost:5000/api/workflows/run",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$env.DIFY_API_KEY}}"
            }
          ]
        },
        "sendBody": true,
        "bodyParametersUi": "keyvaluepairs",
        "bodyParameters": {
          "parameters": [
            {
              "name": "workflow_id",
              "value": "={{$node.webhook_trigger.json.workflow_id}}"
            },
            {
              "name": "inputs",
              "value": "={{$node.webhook_trigger.json.inputs}}"
            }
          ]
        }
      },
      "id": "execute_workflow",
      "name": "Execute Dify Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        500,
        300
      ]
    },
    {
      "parameters": {
        "functionCode": "const response = $input.all()[0].json;\nreturn {\n  workflow_run_id: response.workflow_run_id,\n  status: response.status,\n  outputs: response.outputs,\n  timestamp: new Date().toISOString()\n};"
      },
      "id": "transform_response",
      "name": "Transform Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        750,
        300
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "url": "=http://localhost:5000/api/workflows/{{$node.execute_workflow.json.workflow_run_id}}/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$env.DIFY_API_KEY}}"
            }
          ]
        },
        "sendBody": true,
        "bodyParametersUi": "keyvaluepairs",
        "bodyParameters": {
          "parameters": [
            {
              "name": "message",
              "value": "={{$node.webhook_trigger.json.message}}"
            },
            {
              "name": "query",
              "value": "={{$node.webhook_trigger.json.query}}"
            }
          ]
        }
      },
      "id": "send_message",
      "name": "Send Message to Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1000,
        300
      ]
    },
    {
      "parameters": {
        "httpMethod": "GET",
        "url": "=http://localhost:5000/api/workflows/{{$node.execute_workflow.json.workflow_run_id}}/status",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$env.DIFY_API_KEY}}"
            }
          ]
        }
      },
      "id": "check_workflow_status",
      "name": "Check Workflow Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1250,
        300
      ]
    },
    {
      "parameters": {
        "functionCode": "const status = $input.all()[0].json.status;\nconst isComplete = status === 'completed' || status === 'failed';\nreturn {\n  is_complete: isComplete,\n  status: status,\n  should_retry: status === 'running'\n};"
      },
      "id": "evaluate_status",
      "name": "Evaluate Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1500,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "nodeOutputs": [
            {
              "condition": "===",
              "value1": "={{$node.evaluate_status.json.should_retry}}",
              "value2": true
            }
          ]
        }
      },
      "id": "retry_check",
      "name": "Retry Decision",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        1750,
        300
      ]
    },
    {
      "parameters": {
        "waitTillDate": "={{new Date(Date.now() + 3000).toISOString()}}"
      },
      "id": "wait_before_retry",
      "name": "Wait 3 Seconds",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        2000,
        150
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "url": "={{$env.WEBHOOK_URL}}",
        "authentication": "none",
        "sendBody": true,
        "bodyParametersUi": "json",
        "bodyParameters": {
          "json": {
            "workflow_run_id": "={{$node.execute_workflow.json.workflow_run_id}}",
            "status": "={{$node.check_workflow_status.json.status}}",
            "outputs": "={{$node.check_workflow_status.json.outputs}}",
            "timestamp": "={{$node.transform_response.json.timestamp}}"
          }
        }
      },
      "id": "webhook_response",
      "name": "Send Webhook Response",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2000,
        450
      ]
    },
    {
      "parameters": {
        "functionCode": "return {\n  success: true,\n  message: 'Dify workflow execution completed',\n  workflow_run_id: $input.all()[0].json.workflow_run_id,\n  status: $input.all()[0].json.status\n};"
      },
      "id": "final_output",
      "name": "Final Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2250,
        300
      ]
    }
  ],
  "connections": {
    "webhook_trigger": {
      "main": [
        [
          {
            "node": "execute_workflow",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "execute_workflow": {
      "main": [
        [
          {
            "node": "transform_response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "transform_response": {
      "main": [
        [
          {
            "node": "send_message",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "send_message": {
      "main": [
        [
          {
            "node": "check_workflow_status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check_workflow_status": {
      "main": [
        [
          {
            "node": "evaluate_status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "evaluate_status": {
      "main": [
        [
          {
            "node": "retry_check",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "retry_check": {
      "main": [
        [
          {
            "node": "wait_before_retry",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "webhook_response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "wait_before_retry": {
      "main": [
        [
          {
            "node": "check_workflow_status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "webhook_response": {
      "main": [
        [
          {
            "node": "final_output",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}