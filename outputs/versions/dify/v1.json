{
  "name": "Dify LLM App Development Platform",
  "nodes": [
    {
      "parameters": {},
      "id": "webhook_trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [50, 200],
      "webhookId": "dify-workflow"
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "url": "=YOUR_DIFY_API_ENDPOINT/apps/completion-messages",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer =YOUR_DIFY_API_KEY"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParametersJson": "={\n  \"inputs\": $json.body,\n  \"response_mode\": \"blocking\",\n  \"user\": $json.user_id || \"anonymous\"\n}"
      },
      "id": "call_dify_api",
      "name": "Call Dify API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [300, 200]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "workflow_status",
              "value": "=if($json.answer) { \"completed\" } else { \"failed\" }"
            },
            {
              "name": "result_message",
              "value": "=$json.answer || $json.error"
            },
            {
              "name": "usage_tokens",
              "value": "=$json.usage"
            }
          ]
        }
      },
      "id": "transform_response",
      "name": "Transform Response",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [550, 200]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "url": "=YOUR_WEBHOOK_URL_FOR_LOGGING",
        "sendBody": true,
        "bodyParametersJson": "={\n  \"workflow_id\": $json.workflow_id,\n  \"status\": $json.workflow_status,\n  \"result\": $json.result_message,\n  \"tokens_used\": $json.usage_tokens,\n  \"timestamp\": $now.toISOString()\n}"
      },
      "id": "log_workflow_execution",
      "name": "Log Workflow Execution",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [800, 200],
      "onError": "continueErrorHandling"
    },
    {
      "parameters": {
        "functionCode": "return {\n  success: true,\n  message: $input.first().json.result_message,\n  execution_time: new Date() - new Date($input.first().json.timestamp),\n  tokens: $input.first().json.usage_tokens\n};"
      },
      "id": "format_final_output",
      "name": "Format Final Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1050, 200]
    }
  ],
  "connections": {
    "webhook_trigger": {
      "main": [
        [
          {
            "node": "call_dify_api",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "call_dify_api": {
      "main": [
        [
          {
            "node": "transform_response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "transform_response": {
      "main": [
        [
          {
            "node": "log_workflow_execution",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "log_workflow_execution": {
      "main": [
        [
          {
            "node": "format_final_output",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "versionId": "1.0.0"
}