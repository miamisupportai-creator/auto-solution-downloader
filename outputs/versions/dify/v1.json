{
  "name": "Dify LLM Application Platform",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.dify.ai/v1/workflows",
        "authentication": "bearerToken",
        "nodeCredentialType": "httpHeaderAuth"
      },
      "id": "fetch-workflows",
      "name": "Fetch Workflows",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        300
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_key"
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.dify.ai/v1/models",
        "authentication": "bearerToken",
        "nodeCredentialType": "httpHeaderAuth"
      },
      "id": "fetch-models",
      "name": "Fetch Supported Models",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        650,
        300
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_key"
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.dify.ai/v1/datasets",
        "authentication": "bearerToken",
        "nodeCredentialType": "httpHeaderAuth"
      },
      "id": "fetch-datasets",
      "name": "Fetch RAG Datasets",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        850,
        300
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_key"
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.dify.ai/v1/agents",
        "authentication": "bearerToken",
        "nodeCredentialType": "httpHeaderAuth"
      },
      "id": "fetch-agents",
      "name": "Fetch Agents",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1050,
        300
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_key"
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.dify.ai/v1/apps",
        "authentication": "bearerToken",
        "nodeCredentialType": "httpHeaderAuth"
      },
      "id": "fetch-apps",
      "name": "Fetch Applications",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1250,
        300
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_key"
      }
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "workflows",
              "value": "{{ $node[\"Fetch Workflows\"].json.data }}"
            },
            {
              "name": "models",
              "value": "{{ $node[\"Fetch Supported Models\"].json.data }}"
            },
            {
              "name": "datasets",
              "value": "{{ $node[\"Fetch RAG Datasets\"].json.data }}"
            },
            {
              "name": "agents",
              "value": "{{ $node[\"Fetch Agents\"].json.data }}"
            },
            {
              "name": "applications",
              "value": "{{ $node[\"Fetch Applications\"].json.data }}"
            }
          ]
        }
      },
      "id": "aggregate-data",
      "name": "Aggregate Platform Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.3,
      "position": [
        1450,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.dify.ai/v1/completion-messages",
        "authentication": "bearerToken",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "application/json",
        "body": {
          "inputs": {},
          "query": "Summarize the current state of all workflows, models, datasets, agents and applications"
        }
      },
      "id": "llm-analysis",
      "name": "LLM Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1650,
        300
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_key"
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.dify.ai/v1/logging/telemetry",
        "authentication": "bearerToken",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "application/json",
        "body": {
          "event": "platform_monitoring",
          "timestamp": "{{ $now.toIso() }}",
          "data": "{{ $node[\"Aggregate Platform Data\"].json }}"
        }
      },
      "id": "send-telemetry",
      "name": "Send Telemetry",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1850,
        300
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_key"
      }
    },
    {
      "parameters": {
        "text": "=== Dify Platform Monitoring Report ===\n\nWorkflows: {{ $node[\"Aggregate Platform Data\"].json.workflows.length }} active\nModels: {{ $node[\"Aggregate Platform Data\"].json.models.length }} available\nDatasets: {{ $node[\"Aggregate Platform Data\"].json.datasets.length }} configured\nAgents: {{ $node[\"Aggregate Platform Data\"].json.agents.length }} deployed\nApplications: {{ $node[\"Aggregate Platform Data\"].json.applications.length }} running\n\nLLM Analysis:\n{{ $node[\"LLM Analysis\"].json.answer }}\n\nStatus: COMPLETE\nTimestamp: {{ $now.toIso() }}"
      },
      "id": "output-report",
      "name": "Output Monitoring Report",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.3,
      "position": [
        2050,
        300
      ]
    }
  ],
  "connections": {
    "schedule-trigger": {
      "main": [
        [
          {
            "node": "fetch-workflows",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetch-workflows": {
      "main": [
        [
          {
            "node": "fetch-models",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetch-models": {
      "main": [
        [
          {
            "node": "fetch-datasets",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetch-datasets": {
      "main": [
        [
          {
            "node": "fetch-agents",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetch-agents": {
      "main": [
        [
          {
            "node": "fetch-apps",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetch-apps": {
      "main": [
        [
          {
            "node": "aggregate-data",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "aggregate-data": {
      "main": [
        [
          {
            "node": "llm-analysis",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "llm-analysis": {
      "main": [
        [
          {
            "node": "send-telemetry",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "send-telemetry": {
      "main": [
        [
          {
            "node": "output-report",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1"
  }
}