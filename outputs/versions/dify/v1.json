{
  "name": "Dify LLM Application Development Platform",
  "nodes": [
    {
      "parameters": {},
      "id": "e6f3b4d2-1a2c-4e5f-9a3b-7c2d8e1f5a9b",
      "name": "Start",
      "type": "n8n-nodes-base.start",
      "typeVersion": 1,
      "position": [50, 50]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.dify.ai/v1/workflows"
      },
      "id": "a1b2c3d4-e5f6-47a8-b9c0-d1e2f3a4b5c6",
      "name": "Fetch Workflows",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [250, 50]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.dify.ai/v1/models"
      },
      "id": "b2c3d4e5-f6a7-48b9-c0d1-e2f3a4b5c6d7",
      "name": "Fetch Models",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [250, 150]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.dify.ai/v1/rag-pipelines"
      },
      "id": "c3d4e5f6-a7b8-49ca-d1e2-f3a4b5c6d7e8",
      "name": "Fetch RAG Pipelines",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [250, 250]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.dify.ai/v1/agents"
      },
      "id": "d4e5f6a7-b8c9-4adb-e2f3-a4b5c6d7e8f9",
      "name": "Fetch Agents",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [250, 350]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.dify.ai/v1/apps"
      },
      "id": "e5f6a7b8-c9da-4bec-f3a4-b5c6d7e8f9a0",
      "name": "Fetch Applications",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [250, 450]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.dify.ai/v1/observability/metrics"
      },
      "id": "f6a7b8c9-daeb-4cfd-a4b5-c6d7e8f9a0b1",
      "name": "Fetch Observability Metrics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [250, 550]
    },
    {
      "parameters": {
        "mappings": {
          "workflows": "{{ $node[\"Fetch Workflows\"].json }}",
          "models": "{{ $node[\"Fetch Models\"].json }}",
          "rag_pipelines": "{{ $node[\"Fetch RAG Pipelines\"].json }}",
          "agents": "{{ $node[\"Fetch Agents\"].json }}",
          "applications": "{{ $node[\"Fetch Applications\"].json }}",
          "metrics": "{{ $node[\"Fetch Observability Metrics\"].json }}"
        }
      },
      "id": "a7b8c9da-ebfc-4d0e-b5c6-d7e8f9a0b1c2",
      "name": "Aggregate Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.5,
      "position": [450, 250]
    },
    {
      "parameters": {
        "code": "const workflows = $input.all()[0].json.workflows || [];\nconst models = $input.all()[0].json.models || [];\nconst agents = $input.all()[0].json.agents || [];\nconst apps = $input.all()[0].json.applications || [];\nconst metrics = $input.all()[0].json.metrics || [];\n\nreturn {\n  summary: {\n    total_workflows: Array.isArray(workflows) ? workflows.length : 0,\n    total_models: Array.isArray(models) ? models.length : 0,\n    total_agents: Array.isArray(agents) ? agents.length : 0,\n    total_applications: Array.isArray(apps) ? apps.length : 0,\n    observability_enabled: metrics.length > 0\n  },\n  platform_status: 'operational',\n  timestamp: new Date().toISOString()\n};"
      },
      "id": "b8c9daeb-fcad-4e0f-c6d7-e8f9a0b1c2d3",
      "name": "Process Platform Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 250]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.dify.ai/v1/logs/ingest",
        "body": "{{ $json }}"
      },
      "id": "c9daebfc-ad0e-4f0f-d7e8-f9a0b1c2d3e4",
      "name": "Log Platform State",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [850, 250]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "key": "{{ $json.platform_status }}",
              "condition": "equals",
              "value": "operational"
            }
          ]
        }
      },
      "id": "daebfcad-0e1f-5010-e8f9-a0b1c2d3e4f5",
      "name": "Status Check",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1050, 250]
    },
    {
      "parameters": {
        "mode": "raw",
        "jsonOutput": "{{ $json }}"
      },
      "id": "ebfcad0e-1f2f-5110-f9a0-b1c2d3e4f5a6",
      "name": "Success Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1250, 150]
    },
    {
      "parameters": {
        "mode": "raw",
        "jsonOutput": "{{ { error: 'Platform check failed', status: $json.platform_status } }}"
      },
      "id": "fcad0e1f-2f3f-5210-a0b1-c2d3e4f5a6b7",
      "name": "Error Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1250, 350]
    }
  ],
