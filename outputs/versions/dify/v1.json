{
  "name": "Dify LLM Application Development Platform",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        }
      },
      "id": "trigger-scheduler",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.schedule",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.dify.ai/v1/apps",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth"
      },
      "id": "fetch-apps",
      "name": "Fetch Dify Apps",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        450,
        300
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_key"
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.dify.ai/v1/models",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth"
      },
      "id": "fetch-models",
      "name": "Fetch Available Models",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        650,
        300
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_key"
      }
    },
    {
      "parameters": {
        "functionCode": "return {\n  apps: $input.all()[0].json.data || [],\n  models: $input.all()[1].json.data || [],\n  timestamp: new Date().toISOString(),\n  status: 'active'\n};"
      },
      "id": "aggregate-data",
      "name": "Aggregate Platform Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        850,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.dify.ai/v1/workflows/execute",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "bodyParametersUi": "keyvaluepairs",
        "bodyParameters": {
          "parameters": [
            {
              "name": "inputs",
              "value": "={{$json.aggregated_inputs}}"
            },
            {
              "name": "user",
              "value": "n8n-automation"
            }
          ]
        }
      },
      "id": "execute-workflow",
      "name": "Execute Dify Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1050,
        300
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_key"
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.dify.ai/v1/logs",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth"
      },
      "id": "fetch-logs",
      "name": "Fetch Execution Logs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1250,
        300
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_key"
      }
    },
    {
      "parameters": {
        "mode": "raw",
        "jsonOutput": "{\n  \"workflow_id\": \"{{ $json.workflow_id }}\",\n  \"execution_status\": \"{{ $json.status }}\",\n  \"timestamp\": \"{{ now.toISOString() }}\",\n  \"models_used\": \"{{ $json.models }}\",\n  \"app_count\": \"{{ $json.apps.length }}\",\n  \"logs\": \"{{ $json.logs }}\"\n}"
      },
      "id": "format-output",
      "name": "Format Workflow Output",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [
        1450,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "result",
              "value": "={\n  \"platform\": \"Dify\",\n  \"execution_type\": \"automated_workflow\",\n  \"workflow_data\": $json,\n  \"completion_time\": new Date().toISOString()\n}"
            }
          ]
        }
      },
      "id": "final-transform",
      "name": "Final Data Transform",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [
        1650,
        300
      ]
    }
  ],
  "connections": {
    "trigger-scheduler": {
      "main": [
        [
          {
            "node": "fetch-apps",
            "type": "main",
            "index": 0
          },
          {
            "node": "fetch-models",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetch-apps": {
      "main": [
        [
          {
            "node": "aggregate-data",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetch-models": {
      "main": [
        [
          {
            "node": "aggregate-data",
            "type": "main",
            "index": 1
          }
        ]
      ]
    },
    "aggregate-data": {
      "main": [
        [
          {
            "node": "execute-workflow",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "execute-workflow": {
      "main": [
        [
          {
            "node": "fetch-logs",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetch-logs": {
      "main": [
        [
          {
            "node": "format-output",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "format-output": {
      "main": [
        [
          {
            "node": "final-transform",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveDataErrorExecution": "all",
    "saveDataSuccessExecution": "all",
    "saveManualExecutions": true,
    "timezone": "UTC"
  },
  "staticData": null,
  "tags": [
    "dify",
    "llm",
    "workflow",
    "automation"
  ]
}