{
  "name": "Dify Platform Integration",
  "nodes": [
    {
      "parameters": {},
      "id": "webhook-trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://{{ $env.DIFY_API_URL }}/api/v1/workflows",
        "authentication": "bearerToken",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "workflow_id",
              "value": "={{ $node.webhook-trigger.json.workflow_id }}"
            },
            {
              "name": "inputs",
              "value": "={{ $node.webhook-trigger.json.inputs }}"
            }
          ]
        },
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.DIFY_API_KEY }}"
            }
          ]
        }
      },
      "id": "http-request-workflow",
      "name": "HTTP Request - Execute Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://{{ $env.DIFY_API_URL }}/api/v1/workflows/{{ $node.webhook-trigger.json.workflow_id }}/runs/{{ $node['http-request-workflow'].json.run_id }}",
        "authentication": "bearerToken"
      },
      "id": "http-request-get-status",
      "name": "HTTP Request - Get Workflow Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "operation": "set",
        "nodeToExecuteOnMissing": "Set workflow response"
      },
      "id": "set-response-data",
      "name": "Set Response Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.3,
      "position": [
        850,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://{{ $env.DIFY_API_URL }}/api/v1/datasets",
        "authentication": "bearerToken",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "name",
              "value": "={{ $node.webhook-trigger.json.dataset_name }}"
            },
            {
              "name": "description",
              "value": "={{ $node.webhook-trigger.json.description }}"
            }
          ]
        }
      },
      "id": "http-request-create-dataset",
      "name": "HTTP Request - Create Dataset",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        450
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://{{ $env.DIFY_API_URL }}/api/v1/datasets/{{ $node['http-request-create-dataset'].json.id }}/documents",
        "authentication": "bearerToken",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "file",
              "value": "={{ $node.webhook-trigger.json.file_content }}"
            }
          ]
        }
      },
      "id": "http-request-upload-document",
      "name": "HTTP Request - Upload Document",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        650,
        450
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://{{ $env.DIFY_API_URL }}/api/v1/models",
        "authentication": "bearerToken"
      },
      "id": "http-request-list-models",
      "name": "HTTP Request - List Models",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        600
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://{{ $env.DIFY_API_URL }}/api/v1/applications",
        "authentication": "bearerToken",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "name",
              "value": "={{ $node.webhook-trigger.json.app_name }}"
            },
            {
              "name": "model_id",
              "value": "={{ $node.webhook-trigger.json.model_id }}"
            },
            {
              "name": "prompt",
              "value": "={{ $node.webhook-trigger.json.prompt }}"
            }
          ]
        }
      },
      "id": "http-request-create-app",
      "name": "HTTP Request - Create Application",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        650,
        600
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://{{ $env.DIFY_API_URL }}/api/v1/applications/{{ $node['http-request-create-app'].json.id }}/logs",
        "authentication": "bearerToken",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "status",
              "value": "={{ $node['http-request-workflow'].json.status }}"
            },
            {
              "name": "timestamp",
              "value": "={{ Date.now() }}"
            }
          ]
        }
      },
      "id": "http-request-log-app-activity",
      "name": "HTTP Request - Log App Activity",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        850,
        600
      ]
    },
    {
      "parameters": {
        "code": "// Process workflow execution results\nconst result = $input.all();\nconst processedData = result.map(item => ({\n  workflow_id: item.json.workflow_id,\n  status: item.json.status,\n  output: item.json.output,\n  timestamp: new Date().toISOString()\n}));\nreturn processedData;"
      },
      "id": "code-process-results",
      "name": "Code - Process Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1050,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://{{ $env.DIFY_API_URL }}/api/v1/applications/{{ $node['http-request-create-app'].json.id }}/invoke",
        "authentication": "bearerToken",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "query",
              "value": "={{ $node.webhook-trigger.json.query }}"
            },
            {
              "name": "context",
              "value": "={{ $node['http-request-workflow'].json.context }}"
            }
          ]
        }
      },
      "id": "http-request-invoke-app",
      "name": "HTTP Request - Invoke Application",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        850,
        450
      ]
    }
  ],
  "connections": {
    "webhook-trigger": {
      "main": [
        [
          {
            "node": "http-request-workflow",
            "type": "main",
            "index": 0
          },
          {
            "node": "http-request-create-dataset",
            "type": "main",
            "index": 0
          },
          {
            "node": "http-request-list-models",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "http-request-workflow": {
      "main": [
        [
          {
            "node": "http-request-get-status",
            "type": "main",
            "index": 0
          },
          {
            "node": "http-request-create-app",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "http-request-get-status": {
      "main": [
        [
          {
            "node": "set-response-data",
            "type": "main",
            "index": 0
          },
          {
            "node": "code-process-results",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "http-request-create-dataset": {
      "main": [
        [
          {
            "node": "http-request-upload-document",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "http-request-list-models": {
      "main": [
        [
          {
            "node": "http-request-create-app",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "http-request-create-app": {
      "main": [
        [
          {
            "node": "http-request-invoke-app",
            "type": "main",
            "index": 0
          },
          {
            "node": "http-request-log-app-activity",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "http-request-invoke-app": {
      "main": [
        [
          {
            "node": "http-request-log-app-activity",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "nodeTypes": {
    "n8n-nodes-base.webhook": {},
    "n8n-nodes-base.httpRequest": {},
    "n8n-nodes-base.set": {},
    "n8n-nodes-base.code": {}
  },
  "settings": {
    "executionOrder": "v1"
  }
}