    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $node[\"set-action-state\"].json.llm_api_key }}"
            }
          ]
        },
        "jsonActive": true,
        "jsonData": {
          "model": "gpt-4o-mini",
          "messages": [
            {
              "role": "system",
              "content": "You are a professional cover letter writer. Generate a compelling, personalized cover letter tailored to the specific job description."
            },
            {
              "role": "user",
              "content": "Write a cover letter for this candidate: {{ JSON.stringify($node[\"set-action-state\"].json.resume_data) }}"
            }
          ],
          "max_tokens": 1500
        }
      },
      "id": "generate-cover-letter-llm",
      "name": "Generate Cover Letter via LLM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1250,
        500
      ]
    },
    {
      "parameters": {
        "functionCode": "const action = $input.all()[0].json.action || 'unknown';\nconst timestamp = new Date().toISOString().split('T')[0];\n\nlet filename = '';\nswitch(action) {\n  case 'generate_resume':\n    filename = `resume_base_${timestamp}.pdf`;\n    break;\n  case 'generate_resume_tailored':\n    filename = `resume_tailored_${timestamp}.pdf`;\n    break;\n  case 'generate_cover_letter':\n    filename = `cover_letter_${timestamp}.pdf`;\n    break;\n  default:\n    filename = `document_${timestamp}.pdf`;\n}\n\nreturn {\n  filename: filename,\n  output_path: `./data_folder/output/${filename}`,\n  timestamp: timestamp\n};"
      },
      "id": "prepare-output",
      "name": "Prepare Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1450,
        300
      ]
    },
    {
      "parameters": {
        "functionCode": "const fs = require('fs');\nconst path = require('path');\n\nconst outputData = $input.all()[0].json;\nconst outputPath = outputData.output_path;\nconst outputDir = path.dirname(outputPath);\n\n// Ensure output directory exists\nif (!fs.existsSync(outputDir)) {\n  fs.mkdirSync(outputDir, { recursive: true });\n}\n\nreturn {\n  success: true,\n  message: `Document generated: ${outputData.filename}`,\n  file_path: outputPath,\n  timestamp: outputData.timestamp\n};"
      },
      "id": "save-document",
      "name": "Save Document",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1650,
        300
      ]
    }
