              "value": "Bearer {{ $node[\"set-action-state\"].json.llm_api_key }}"
            }
          ]
        },
        "jsonActive": true,
        "jsonData": {
          "model": "gpt-4o-mini",
          "messages": [
            {
              "role": "system",
              "content": "You are a professional resume writer. Generate a professional resume in PDF format based on the provided information."
            },
            {
              "role": "user",
              "content": "Create a professional resume based on this information: {{ JSON.stringify($node[\"set-action-state\"].json.resume_data) }}"
            }
          ],
          "max_tokens": 2000
        }
      },
      "id": "generate-resume-llm",
      "name": "Generate Resume via LLM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
