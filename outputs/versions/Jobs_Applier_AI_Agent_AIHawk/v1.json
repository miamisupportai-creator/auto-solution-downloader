        "jsonData": {
          "model": "gpt-4o-mini",
          "messages": [
            {
              "role": "system",
              "content": "You are a professional resume writer specializing in tailoring resumes for specific job descriptions. Generate a tailored resume based on the job description and candidate information."
            },
            {
              "role": "user",
              "content": "Tailor this resume for the job description. Resume: {{ JSON.stringify($node[\"set-action-state\"].json.resume_data) }}"
            }
          ],
          "max_tokens": 2500
