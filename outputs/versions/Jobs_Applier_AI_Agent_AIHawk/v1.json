{
  "name": "AIHawk Jobs Applier AI Agent",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": [
          {
            "mode": "everyX",
            "value": 1,
            "unit": "days"
          }
        ]
      },
      "id": "schedule-trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "functionCode": "const fs = require('fs');\nconst yaml = require('js-yaml');\nconst path = require('path');\n\nconst dataFolder = './data_folder';\nconst secretsFile = path.join(dataFolder, 'secrets.yaml');\nconst configFile = path.join(dataFolder, 'work_preferences.yaml');\nconst resumeFile = path.join(dataFolder, 'plain_text_resume.yaml');\n\ntry {\n  const secrets = yaml.load(fs.readFileSync(secretsFile, 'utf8'));\n  const config = yaml.load(fs.readFileSync(configFile, 'utf8'));\n  const resume = yaml.load(fs.readFileSync(resumeFile, 'utf8'));\n  \n  return {\n    llm_api_key: secrets.llm_api_key,\n    work_preferences: config,\n    resume: resume\n  };\n} catch (error) {\n  throw new Error(`Failed to load configuration: ${error.message}`);\n}"
      },
      "id": "load-config",
      "name": "Load Configuration",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        450,
        300
      ],
      "credentials": []
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "a1",
              "name": "action",
              "value": "Generate Resume",
              "type": "string"
            },
            {
              "id": "a2",
              "name": "llm_api_key",
              "value": "={{ $node[\"load-config\"].json.llm_api_key }}",
              "type": "string"
            },
            {
              "id": "a3",
              "name": "work_preferences",
              "value": "={{ $node[\"load-config\"].json.work_preferences }}",
              "type": "object"
            },
            {
              "id": "a4",
              "name": "resume_data",
              "value": "={{ $node[\"load-config\"].json.resume }}",
              "type": "object"
            }
          ]
        }
      },
      "id": "set-action-state",
      "name": "Set Action State",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "functionCode": "const action = $input.all()[0].json.action;\n\nif (action === 'Generate Resume') {\n  return { action: 'generate_resume' };\n} else if (action === 'Generate Resume Tailored for Job Description') {\n  return { action: 'generate_resume_tailored' };\n} else if (action === 'Generate Tailored Cover Letter for Job Description') {\n  return { action: 'generate_cover_letter' };\n} else {\n  return { action: 'unknown' };\n}"
      },
      "id": "route-action",
      "name": "Route Action",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        850,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "id": "condition1",
              "operator": {
                "name": "filter.operator.equals",
                "type": "string",
                "value": "equals"
              },
              "leftValue": "={{ $node[\"route-action\"].json.action }}",
              "rightValue": "generate_resume"
            }
          ]
        }
      },
      "id": "if-generate-resume",
      "name": "If Generate Resume",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1050,
        100
      ]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "id": "condition1",
              "operator": {
                "name": "filter.operator.equals",
                "type": "string",
