{
  "name": "AIHawk Jobs Applier - Resume & Cover Letter Generator",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": [
          {
            "mode": "everyDay",
            "hour": 9,
            "minute": 0
          }
        ]
      },
      "id": "trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [
        50,
        300
      ]
    },
    {
      "parameters": {
        "operation": "readFromFile",
        "filePath": "data_folder/secrets.yaml"
      },
      "id": "load_secrets",
      "name": "Load Secrets",
      "type": "n8n-nodes-base.readLocalFile",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "operation": "readFromFile",
        "filePath": "data_folder/work_preferences.yaml"
      },
      "id": "load_config",
      "name": "Load Configuration",
      "type": "n8n-nodes-base.readLocalFile",
      "typeVersion": 1,
      "position": [
        250,
        450
      ]
    },
    {
      "parameters": {
        "operation": "readFromFile",
        "filePath": "data_folder/plain_text_resume.yaml"
      },
      "id": "load_resume",
      "name": "Load Resume",
      "type": "n8n-nodes-base.readLocalFile",
      "typeVersion": 1,
      "position": [
        250,
        600
      ]
    },
    {
      "parameters": {
        "code": "const yaml = require('js-yaml');\nconst secretsData = $node[\"Load Secrets\"].json;\nconst configData = $node[\"Load Configuration\"].json;\nconst resumeData = $node[\"Load Resume\"].json;\n\nconst llmApiKey = secretsData.llm_api_key;\nconst config = yaml.load(configData);\nconst resume = yaml.load(resumeData);\n\nreturn {\n  llm_api_key: llmApiKey,\n  config: config,\n  resume: resume,\n  outputFileDirectory: 'data_folder/output'\n};"
      },
      "id": "validate_and_prepare",
      "name": "Validate & Prepare Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        450,
        400
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "What action would you like to perform?\n1. Generate Resume\n2. Generate Resume Tailored for Job Description\n3. Generate Tailored Cover Letter for Job Description",
        "options": {
          "values": [
            {
              "name": "Generate Resume",
              "value": "generate_resume"
            },
            {
              "name": "Generate Resume Tailored for Job Description",
              "value": "generate_resume_tailored"
            },
            {
              "name": "Generate Tailored Cover Letter for Job Description",
              "value": "generate_cover_letter"
            }
          ]
        }
      },
      "id": "prompt_user_action",
      "name": "Prompt User Action",
      "type": "n8n-nodes-base.manualChatTrigger",
      "typeVersion": 1,
      "position": [
        650,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.openai.com/v1/chat/completions",
        "headers": {
          "Authorization": "=Bearer {{ $json.llm_api_key }}"
        },
        "body": {
          "model": "gpt-4",
          "messages": [
            {
              "role": "system",
              "content": "You are a professional resume and cover letter writer. Generate tailored documents based on the job description and user profile."
            },
            {
              "role": "user",
              "content": "=Generate a professional resume based on this profile: {{ JSON.stringify($json.resume) }}"
            }
          ]
        }
      },
      "id": "generate_resume",
      "name": "Generate Resume via LLM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        850,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.openai.com/v1/chat/completions",
        "headers": {
          "Authorization": "=Bearer {{ $json.llm_api_key }}"
        },
        "body": {
          "model": "gpt-4",
          "messages": [
            {
              "role": "system",
              "content": "You are a professional resume writer. Tailor the resume to match the specific job description."
            },
            {
              "role": "user",
              "content": "=Tailor this resume to the job description provided: {{ JSON.stringify($json.resume) }}"
            }
          ]
        }
      },
      "id": "generate_resume_tailored",
      "name": "Generate Tailored Resume via LLM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        850,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.openai.com/v1/chat/completions",
        "headers": {
          "Authorization": "=Bearer {{ $json.llm_api_key }}"
        },
        "body": {
          "model": "gpt-4",
          "messages": [
            {
              "role": "system",
              "content": "You are an expert cover letter writer. Create compelling, personalized cover letters."
            },
            {
              "role": "user",
              "content": "=Create a tailored cover letter for this candidate: {{ JSON.stringify($json.resume) }}"
            }
          ]
        }
      },
      "id": "generate_cover_letter",
      "name": "Generate Cover Letter via LLM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        850,
        600
      ]
    },
    {
      "parameters": {
        "fileName": "=resume_{{ Date.now() }}.pdf",
        "dataPropertyName": "data",
        "mimeType": "application/pdf"
      },
      "id": "save_resume_file",
      "name": "Save Resume File",
      "type": "n8n-nodes-base.writeLocalFile",
      "typeVersion": 1,
      "position": [
        1050,
        200
      ]
    },
    {
      "parameters": {
        "fileName": "=resume_tailored_{{ Date.now() }}.pdf",
        "dataPropertyName": "data",
        "mimeType": "application/pdf"
      },
      "id": "save_tailored_resume_file",
      "name": "Save Tailored Resume File",
      "type": "n8n-nodes-base.writeLocalFile",
      "typeVersion": 1,
      "position": [
        1050,
        400
      ]
    },
    {
      "parameters": {
        "fileName": "=cover_letter_{{ Date.now() }}.pdf",
        "dataPropertyName": "data",
        "mimeType": "application/pdf"
      },
      "id": "save_cover_letter_file",
      "name": "Save Cover Letter File",
      "type": "n8n-nodes-base.writeLocalFile",
      "typeVersion": 1,
      "position": [
        1050,
        600
      ]
    },
    {
      "parameters": {
        "operation": "set",
        "fields": {
          "status": "success",
          "message": "Document generation completed successfully",
          "timestamp": "={{ Date.now() }}"
        }
      },
      "id": "set_success_response",
      "name": "Set Success Response",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [
        1250,
        400
      ]
    }
  ],
