{
  "name": "Khoj File Sync Workflow",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "recurrence": "every",
              "value": 10,
              "unit": "minutes"
            }
          ]
        }
      },
      "id": "schedule_trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduler",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "url": "={{ $env.KHOJ_HOST_URL || 'https://app.khoj.dev' }}/api/v1/user?client=n8n",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.KHOJ_API_TOKEN }}"
            }
          ]
        },
        "options": {}
      },
      "id": "get_khoj_token",
      "name": "Get Khoj Token",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "functionCode": "const fs = require('fs');\nconst path = require('path');\n\nconst fileTypesSupported = {\n  text: ['org', 'md', 'markdown', 'txt', 'html', 'xml', 'c', 'cs', 'css', 'csv', 'go', 'java', 'js', 'json', 'py', 'rb', 'rs'],\n  binary: ['pdf', 'jpg', 'jpeg', 'png', 'webp']\n};\n\nconst allTypes = Object.values(fileTypesSupported).flat();\n\nfunction isSupportedFileType(filePath) {\n  const ext = filePath.split('.').pop().toLowerCase();\n  return allTypes.includes(ext);\n}\n\nfunction getMimeType(filePath) {\n  const ext = filePath.split('.').pop().toLowerCase();\n  const mimeMap = {\n    'pdf': 'application/pdf',\n    'png': 'image/png',\n    'jpg': 'image/jpeg',\n    'jpeg': 'image/jpeg',\n    'webp': 'image/webp',\n    'md': 'text/markdown',\n    'markdown': 'text/markdown',\n    'org': 'text/org'\n  };\n  return mimeMap[ext] || 'text/plain';\n}\n\nconst filePath = $input.all()[0].json.filePath;\n\nif (!fs.existsSync(filePath)) {\n  return { error: `File does not exist: ${filePath}` };\n}\n\nif (!isSupportedFileType(filePath)) {\n  return { error: `Unsupported file type for: ${filePath}` };\n}\n\nconst stats = fs.statSync(filePath);\nconst isBinary = fileTypesSupported.binary.includes(filePath.split('.').pop().toLowerCase());\n\nreturn {\n  filePath: filePath,\n  mimeType: getMimeType(filePath),\n  fileSize: stats.size,\n  modified: stats.mtime.toISOString(),\n  isBinary: isBinary\n};"
      },
      "id": "validate_files",
      "name": "Validate File Types",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "url": "={{ $env.KHOJ_HOST_URL || 'https://app.khoj.dev' }}/api/content?client=n8n",
        "method": "PATCH",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.KHOJ_API_TOKEN }}"
            }
          ]
        },
        "sendBody": true,
        "bodyParametersUi": "keyvaluepairs",
        "bodyParameters": {
          "parameters": [
            {
              "name": "files",
              "value": "={{ $json.filePath }}"
            }
          ]
        }
      },
      "id": "push_files_khoj",
      "name": "Push Files to Khoj",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        850,
        300
      ]
    },
    {
      "parameters": {
        "functionCode": "const lastSync = $input.all()[0].json.lastSync || [];\nconst currentTime = new Date().toISOString();\n\nreturn {\n  path: $json.filePath,\n  datetime: currentTime\n};"
      },
      "id": "update_sync_timestamp",
      "name": "Update Sync Timestamp",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1050,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "a1",
              "name": "lastSync",
              "value": "={{ $json.lastSync || [] }}"
            }
          ]
        }
      },
      "id": "set_last_sync",
      "name": "Set Last Sync",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.3,
      "position": [
        1250,
        300
      ]
    },
    {
      "parameters": {
        "errorMessage": "={{ $json.error || 'Unknown error occurred' }}"
      },
      "id": "error_handler",
      "name": "Error Handler",
      "type": "n8n-nodes-base.errorMessage",
      "typeVersion": 1,
      "position": [
        850,
        450
      ]
    }
  ],
  "connections": {
    "schedule_trigger": {
      "main": [
        [
          {
            "node": "get_khoj_token",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "get_khoj_token": {
      "main": [
        [
          {
            "node": "validate_files",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "validate_files": {
      "main": [
        [
          {
            "node": "push_files_khoj",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "push_files_khoj": {
      "main": [
        [
          {
            "node": "update_sync_timestamp",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "update_sync_timestamp": {
      "main": [
        [
          {
            "node": "set_last_sync",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}