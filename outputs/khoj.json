{
  "name": "Khoj Content Sync Workflow",
  "nodes": [
    {
      "parameters": {},
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [250, 250],
      "cronExpression": "0 */10 * * * *"
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "{{ $node[\"Get Config\"].json.khojToken }}",
              "operation": "notEmpty"
            },
            {
              "value1": "{{ $node[\"Get Config\"].json.hostURL }}",
              "operation": "notEmpty"
            }
          ]
        }
      },
      "name": "Validate Configuration",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [450, 250]
    },
    {
      "parameters": {
        "functionCode": "return {\n  khojToken: process.env.KHOJ_TOKEN || '',\n  hostURL: process.env.KHOJ_HOST_URL || 'https://app.khoj.dev',\n  files: [],\n  folders: [],\n  lastSync: []\n};"
      },
      "name": "Get Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [250, 100]
    },
    {
      "parameters": {
        "functionCode": "const files = $input.first().json.files || [];\nconst folders = $input.first().json.folders || [];\nconst filesToIndex = [];\n\n// Collect files to index\nfor (const file of files) {\n  filesToIndex.push(file.path);\n}\n\nreturn { filesToIndex };"
      },
      "name": "Collect Files",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [650, 250]
    },
    {
      "parameters": {
        "functionCode": "const files = $input.first().json.filesToIndex || [];\nconst lastSync = $input.first().json.lastSync || [];\nconst filesToSync = [];\n\n// Filter files that have been modified since last sync\nfor (const file of files) {\n  const lastSyncFile = lastSync.find(f => f.path === file);\n  if (!lastSyncFile) {\n    filesToSync.push(file);\n  }\n}\n\nreturn { filesToSync };"
      },
      "name": "Filter Modified Files",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [850, 250]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "{{ $node[\"Get Config\"].json.hostURL }}/api/content?client=desktop",
        "authentication": "bearerToken",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "files",
              "value": "{{ $json.filesToSync }}"
            }
          ]
        },
        "options": {}
      },
      "name": "Sync Files to Khoj",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1050, 250]
    },
    {
      "parameters": {
        "functionCode": "const response = $input.first().json;\nconst filesToSync = $node[\"Filter Modified Files\"].json.filesToSync || [];\n\nconst lastSync = filesToSync.map(file => ({\n  path: file,\n  datetime: new Date().toISOString()\n}));\n\nreturn { lastSync, success: true };"
      },
      "name": "Update Last Sync",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [1250, 250]
    },
    {
      "parameters": {
        "functionCode": "const error = $input.first().json.error || {};\nreturn {\n  success: false,\n  error: error.message || 'Sync failed',\n  timestamp: new Date().toISOString()\n};"
      },
      "name": "Handle Sync Error",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [1050, 450]
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [
        [
          {
            "node": "Get Config",
            "indices": [0]
          }
        ]
      ]
    },
    "Get Config": {
      "main": [
        [
          {
            "node": "Validate Configuration",
            "indices": [0]
          }
        ]
      ]
    },
    "Validate Configuration": {
      "main": [
        [
          {
            "node": "Collect Files",
            "indices": [0]
          }
        ],
        [
          {
            "node": "Handle Sync Error",
            "indices": [0]
          }
        ]
      ]
    },
    "Collect Files": {
      "main": [
        [
          {
            "node": "Filter Modified Files",
            "indices": [0]
          }
        ]
      ]
    },
    "Filter Modified Files": {
      "main": [
        [
          {
            "node": "Sync Files to Khoj",
            "indices": [0]
          }
        ]
      ]
    },
    "Sync Files to Khoj": {
      "main": [
        [
          {
            "node": "Update Last Sync",
            "indices": [0]
          }
        ]
      ],
      "error": [
        [
          {
            "node": "Handle Sync Error",
            "indices": [0]
          }
        ]
      ]
    }
  },
  "settings": {
    "timezone": "UTC"
  }
}