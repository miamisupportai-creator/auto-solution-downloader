{
  "name": "Dify LLM Application Orchestration",
  "nodes": [
    {
      "parameters": {},
      "id": "webhook-trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "default"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://{{$env.DIFY_API_HOST}}/v1/workflows/run",
        "authentication": "genericCredentialType",
        "genericCredentials": "=difyApiKey",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.DIFY_API_KEY}}"
            }
          ]
        },
        "contentType": "application/json",
        "body": "={\"workflow_id\": \"{{$node.webhook-trigger.json.workflow_id}}\", \"inputs\": {{JSON.stringify($node.webhook-trigger.json.inputs)}}, \"user\": \"{{$node.webhook-trigger.json.user_id}}\"}"
      },
      "id": "dify-workflow-executor",
      "name": "Execute Dify Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [500, 300]
    },
    {
      "parameters": {
        "jsonOutput": true,
        "content": "={\n  \"workflow_run_id\": {{$node[\"dify-workflow-executor\"].json.workflow_run_id}},\n  \"status\": {{$node[\"dify-workflow-executor\"].json.status}},\n  \"outputs\": {{$node[\"dify-workflow-executor\"].json.outputs}},\n  \"created_at\": new Date().toISOString()\n}"
      },
      "id": "normalize-response",
      "name": "Normalize Workflow Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [750, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://{{$env.DIFY_API_HOST}}/v1/workflows/{{$node[\"dify-workflow-executor\"].json.workflow_run_id}}/status",
        "authentication": "genericCredentialType",
        "genericCredentials": "=difyApiKey",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.DIFY_API_KEY}}"
            }
          ]
        }
      },
      "id": "poll-workflow-status",
      "name": "Poll Workflow Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1000, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$node[\"poll-workflow-status\"].json.status}}",
              "value2": "completed",
              "operation": "equals"
            }
          ]
        }
      },
      "id": "check-completion",
      "name": "Check Workflow Completion",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.WEBHOOK_CALLBACK_URL}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "contentType": "application/json",
        "body": "={\"workflow_id\": \"{{$node[\"dify-workflow-executor\"].json.workflow_run_id}}\", \"status\": \"{{$node[\"poll-workflow-status\"].json.status}}\", \"result\": {{JSON.stringify($node[\"poll-workflow-status\"].json.outputs)}}}"
      },
      "id": "send-completion-callback",
      "name": "Send Completion Callback",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1500, 200]
    },
    {
      "parameters": {
        "errorMessage": "Workflow execution failed or timed out"
      },
      "id": "handle-error",
      "name": "Handle Execution Error",
      "type": "n8n-nodes-base.error",
      "typeVersion": 1,
      "position": [1500, 400]
    },
    {
      "parameters": {
        "content": "={\n  \"error\": \"Workflow execution incomplete\",\n  \"workflow_id\": \"{{$node[\"dify-workflow-executor\"].json.workflow_run_id}}\",\n  \"last_status\": \"{{$node[\"poll-workflow-status\"].json.status}}\",\n  \"timestamp\": new Date().toISOString()\n}"
      },
      "id": "log-incomplete-execution",
      "name": "Log Incomplete Execution",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1500, 400]
    }
  ],
  "connections": {
    "webhook-trigger": {
      "main": [
        [
          {
            "node": "dify-workflow-executor",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "dify-workflow-executor": {
      "main": [
        [
          {
            "node": "normalize-response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "normalize-response": {
      "main": [
        [
          {
            "node": "poll-workflow-status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "poll-workflow-status": {
      "main": [
        [
          {
            "node": "check-completion",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check-completion": {
      "main": [
        [
          {
            "node": "send-completion-callback",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "log-incomplete-execution",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "pinData": null
}