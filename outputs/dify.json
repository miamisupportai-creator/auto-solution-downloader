{
  "name": "Dify LLM Application Platform",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "GET",
        "url": "=https://api.dify.ai/v1/apps",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "id": "Get_Apps",
      "name": "Get Apps",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [250, 100]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "url": "=https://api.dify.ai/v1/chat-messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "inputs",
              "value": "={{ $json.inputs }}"
            },
            {
              "name": "query",
              "value": "={{ $json.query }}"
            },
            {
              "name": "response_mode",
              "value": "blocking"
            }
          ]
        }
      },
      "id": "Send_Chat_Message",
      "name": "Send Chat Message",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [500, 100]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "url": "=https://api.dify.ai/v1/workflows/run",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "inputs",
              "value": "={{ $json.workflow_inputs }}"
            },
            {
              "name": "user",
              "value": "={{ $json.user_id }}"
            }
          ]
        }
      },
      "id": "Execute_Workflow",
      "name": "Execute Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [750, 100]
    },
    {
      "parameters": {
        "httpMethod": "GET",
        "url": "=https://api.dify.ai/v1/datasets",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "id": "Get_Datasets",
      "name": "Get Datasets",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [250, 250]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "url": "=https://api.dify.ai/v1/datasets/{{ $json.dataset_id }}/documents",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "name",
              "value": "={{ $json.document_name }}"
            },
            {
              "name": "text",
              "value": "={{ $json.document_content }}"
            }
          ]
        }
      },
      "id": "Create_Document",
      "name": "Create Document",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [500, 250]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "url": "=https://api.dify.ai/v1/workflows",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "name",
              "value": "={{ $json.workflow_name }}"
            },
            {
              "name": "description",
              "value": "={{ $json.workflow_description }}"
            }
          ]
        }
      },
      "id": "Create_Workflow",
      "name": "Create Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [750, 250]
    },
    {
      "parameters": {
        "httpMethod": "GET",
        "url": "=https://api.dify.ai/v1/models",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "id": "List_Models",
      "name": "List Models",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [250, 400]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "url": "=https://api.dify.ai/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "app_id",
              "value": "={{ $json.app_id }}"
            },
            {
              "name": "user_id",
              "value": "={{ $json.user_id }}"
            },
            {
              "name": "query",
              "value": "={{ $json.message_content }}"
            }
          ]
        }
      },
      "id": "Create_Message",
      "name": "Create Message",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [500, 400]
    },
    {
      "parameters": {
        "code": "return $json.map(item => ({\n  id: item.id,\n  name: item.name,\n  description: item.description,\n  created_at: item.created_at,\n  updated_at: item.updated_at\n}))"
      },
      "id": "Transform_Response",
      "name": "Transform Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [750, 400]
    },
    {
      "parameters": {},
      "id": "Webhook_Trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 100],
      "webhookId": "dify-webhook"
    }
  ],
  "connections": {
    "Webhook_Trigger": {
      "main": [
        [
          {
            "node": "Get_Apps",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get_Apps": {
      "main": [
        [
          {
            "node": "Send_Chat_Message",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send_Chat_Message": {
      "main": [
        [
          {
            "node": "Execute_Workflow",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get_Datasets": {
      "main": [
        [
          {
            "node": "Create_Document",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Create_Document": {
      "main": [
        [
          {
            "node": "Create_Workflow",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "List_Models": {
      "main": [
        [
          {
            "node": "Create_Message",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Create_Message": {
      "main": [
        [
          {
            "node": "Transform_Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}