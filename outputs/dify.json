{
  "name": "Dify LLM Application Platform",
  "nodes": [
    {
      "parameters": {
        "triggerTopic": "dify.workflow"
      },
      "id": "webhook_trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "url": "=https://api.dify.ai/v1/workflows/{{ $json.workflow_id }}/execute",
        "authentication": "genericCredentialType",
        "genericCredentials": "=dify_api_key",
        "method": "POST",
        "bodyParameters": {
          "parameters": "={{ $json.inputs }}"
        },
        "options": {}
      },
      "id": "execute_workflow",
      "name": "Execute Dify Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        500,
        300
      ]
    },
    {
      "parameters": {
        "url": "=https://api.dify.ai/v1/apps/{{ $json.app_id }}/completion-messages",
        "authentication": "genericCredentialType",
        "genericCredentials": "=dify_api_key",
        "method": "POST",
        "bodyParameters": {
          "inputs": "={{ $json.message_inputs }}",
          "query": "={{ $json.query }}",
          "response_mode": "blocking"
        },
        "options": {}
      },
      "id": "invoke_llm_app",
      "name": "Invoke LLM App",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        750,
        300
      ]
    },
    {
      "parameters": {
        "url": "=https://api.dify.ai/v1/datasets/{{ $json.dataset_id }}/documents",
        "authentication": "genericCredentialType",
        "genericCredentials": "=dify_api_key",
        "method": "POST",
        "bodyParameters": {
          "name": "={{ $json.document_name }}",
          "text": "={{ $json.document_content }}"
        },
        "options": {}
      },
      "id": "upload_knowledge_base",
      "name": "Upload to Knowledge Base",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        750,
        450
      ]
    },
    {
      "parameters": {
        "url": "=https://api.dify.ai/v1/apps/{{ $json.app_id }}/logs",
        "authentication": "genericCredentialType",
        "genericCredentials": "=dify_api_key",
        "method": "GET",
        "qs": {
          "limit": "={{ $json.log_limit || 100 }}",
          "offset": "={{ $json.log_offset || 0 }}"
        },
        "options": {}
      },
      "id": "fetch_app_logs",
      "name": "Fetch App Logs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1000,
        300
      ]
    },
    {
      "parameters": {
        "url": "=https://api.dify.ai/v1/apps/{{ $json.app_id }}/advanced_logs",
        "authentication": "genericCredentialType",
        "genericCredentials": "=dify_api_key",
        "method": "GET",
        "qs": {
          "limit": "={{ $json.analytics_limit || 50 }}"
        },
        "options": {}
      },
      "id": "fetch_analytics",
      "name": "Fetch Analytics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1000,
        450
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "workflow_status",
              "value": "=completed",
              "type": "string"
            },
            {
              "id": "execution_time",
              "value": "={{ new Date().toISOString() }}",
              "type": "string"
            },
            {
              "id": "result_summary",
              "value": "=Workflow executed successfully",
              "type": "string"
            }
          ]
        }
      },
      "id": "transform_results",
      "name": "Transform Results",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.3,
      "position": [
        1250,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json.webhook_url }}",
        "body": "={{ $json }}",
        "options": {}
      },
      "id": "webhook_callback",
      "name": "Send Webhook Callback",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1500,
        300
      ]
    },
    {
      "parameters": {
        "errorMessage": "=Workflow execution failed",
        "triggerType": "errorMessage"
      },
      "id": "error_handler",
      "name": "Error Handler",
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [
        500,
        600
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "error_status",
              "value": "=error",
              "type": "string"
            },
            {
              "id": "error_details",
              "value": "={{ $json.error.message }}",
              "type": "string"
            }
          ]
        }
      },
      "id": "format_error",
      "name": "Format Error Response",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.3,
      "position": [
        750,
        600
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json.error_webhook_url }}",
        "body": "={{ $json }}",
        "options": {}
      },
      "id": "error_webhook",
      "name": "Send Error Callback",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1000,
        600
      ]
    }
  ],
  "connections": {
    "webhook_trigger": {
      "main": [
        [
          {
            "node": "execute_workflow",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "execute_workflow": {
      "main": [
        [
          {
            "node": "invoke_llm_app",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "invoke_llm_app": {
      "main": [
        [
          {
            "node": "fetch_app_logs",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetch_app_logs": {
      "main": [
        [
          {
            "node": "fetch_analytics",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetch_analytics": {
      "main": [
        [
          {
            "node": "transform_results",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "transform_results": {
      "main": [
        [
          {
            "node": "webhook_callback",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "error_handler": {
      "main": [
        [
          {
            "node": "format_error",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "format_error": {
      "main": [
        [
          {
            "node": "error_webhook",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "tags": [],
  "triggerCount": 0,
  "pinData": {}
}