{
  "name": "Dify LLM Application Platform",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        }
      },
      "id": "trigger-schedule",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.dify.ai/v1/workflows/run",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $credentials.difyApiKey }}"
            }
          ]
        },
        "contentType": "application/json",
        "body": "{\n  \"inputs\": {\n    \"query\": \"{{ $node[\\\"input-data\\\"].json.query }}\"\n  },\n  \"user\": \"n8n-user\"\n}"
      },
      "id": "dify-workflow-execute",
      "name": "Execute Dify Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        300
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_credentials"
      }
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "workflow_id",
              "value": "={{ $node[\\\"dify-workflow-execute\\\"].json.workflow_run_id }}"
            },
            {
              "name": "status",
              "value": "={{ $node[\\\"dify-workflow-execute\\\"].json.status }}"
            },
            {
              "name": "output",
              "value": "={{ $node[\\\"dify-workflow-execute\\\"].json.data }}"
            }
          ]
        }
      },
      "id": "transform-response",
      "name": "Transform Response",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.3,
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.dify.ai/v1/chat-messages",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $credentials.difyApiKey }}"
            }
          ]
        },
        "contentType": "application/json",
        "body": "{\n  \"inputs\": {\n    \"user_message\": \"{{ $node[\\\"input-data\\\"].json.message }}\"\n  },\n  \"response_mode\": \"blocking\",\n  \"user\": \"n8n-chat-user\"\n}"
      },
      "id": "dify-chat-message",
      "name": "Send Chat Message to Dify",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        450
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_credentials"
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.dify.ai/v1/workflows/{{ $node[\\\"transform-response\\\"].json.workflow_id }}",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $credentials.difyApiKey }}"
            }
          ]
        }
      },
      "id": "get-workflow-status",
      "name": "Get Workflow Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        850,
        300
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_credentials"
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.dify.ai/v1/rag/documents",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $credentials.difyApiKey }}"
            }
          ]
        },
        "contentType": "application/json",
        "body": "{\n  \"name\": \"{{ $node[\\\"input-data\\\"].json.document_name }}\",\n  \"content\": \"{{ $node[\\\"input-data\\\"].json.content }}\",\n  \"data_source\": \"{{ $node[\\\"input-data\\\"].json.data_source }}\"\n}"
      },
      "id": "rag-document-upload",
      "name": "Upload RAG Document",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        600
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_credentials"
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.dify.ai/v1/models",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $credentials.difyApiKey }}"
            }
          ]
        }
      },
      "id": "list-available-models",
      "name": "List Available Models",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        250,
        600
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_credentials"
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.dify.ai/v1/agents/run",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $credentials.difyApiKey }}"
            }
          ]
        },
        "contentType": "application/json",
        "body": "{\n  \"agent_id\": \"{{ $node[\\\"input-data\\\"].json.agent_id }}\",\n  \"tools\": {{ $node[\\\"input-data\\\"].json.tools }},\n  \"query\": \"{{ $node[\\\"input-data\\\"].json.query }}\"\n}"
      },
      "id": "execute-agent",
      "name": "Execute Agent",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        650,
        450
      ],
      "credentials": {
        "httpHeaderAuth": "dify_api_credentials"
      }
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "condition": "equal",
              "leftValue": "={{ $node[\\\"get-workflow-status\\\"].json.status }}",
              "rightValue": "completed"
            }
          ]
        }
      },
      "id": "check-completion",
      "name": "Check Completion Status",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1050,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "final_output",
              "value": "={{ $node[\\\"transform-response\\\"].json.output }}"
            },
            {
              "name": "execution_status",
              "value": "=completed"
            },
            {
              "name": "timestamp",
              "value": "={{ new Date().toISOString() }}"
            }
          ]
        }
      },
      "id": "prepare-final-output",
      "name": "Prepare Final Output",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.3,
      "position": [
        1250,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $node[\\\"input-data\\\"].json.webhook_url }}",
        "contentType": "application/json",
        "body": "={\n  \"status\": \"{{ $node[\\\"prepare-final-output\\\"].json.execution_status }}\",\n  \"output\": {{ JSON.stringify($node[\\\"prepare-final-output\\\"].json.final_output) }},\n  \"timestamp\": \"{{ $node[\\\"prepare-final-output\\\"].json.timestamp }}\"\n}"
      },
      "id": "send-webhook-notification",
      "name": "Send Webhook Notification",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1450,
        200
      ]
    },
    {
      "parameters": {},
      "id": "input-data",
      "name": "Input Data",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [
        100,
        300
      ]
    }
  ],
  "connections": {
    "trigger-schedule": {
      "main": [
        [
          {
            "node": "input-data",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "input-data": {
      "main": [
        [
          {
            "node": "dify-workflow-execute",
            "type": "main",
            "index": 0
          },
          {
            "node": "list-available-models",
            "type": "main",
            "index": 0
          },
          {
            "node": "dify-chat-message",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "dify-workflow-execute": {
      "main": [
        [
          {
            "node": "transform-response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "transform-response": {
      "main": [
        [
          {
            "node": "get-workflow-status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "dify-chat-message": {
      "main": [
        [
          {
            "node": "execute-agent",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "get-workflow-status": {
      "main": [
        [
          {
            "node": "check-completion",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check-completion": {
      "main": [
        [
          {
            "node": "prepare-final-output",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "rag-document-upload",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "prepare-final-output": {
      "main": [
        [
          {
            "node": "send-webhook-notification",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "execute-agent": {
      "main": [
        [
          {
            "node": "prepare-final-output",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  }
}