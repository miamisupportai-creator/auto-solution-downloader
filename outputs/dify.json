{
  "name": "Dify LLM App Development Platform",
  "nodes": [
    {
      "parameters": {},
      "id": "trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        50,
        300
      ],
      "webhookId": "dify-webhook"
    },
    {
      "parameters": {
        "url": "=https://api.dify.ai/workflows/execute",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "workflow_id",
              "value": "={{ $node.trigger.json.workflow_id }}"
            },
            {
              "name": "inputs",
              "value": "={{ $node.trigger.json.inputs }}"
            }
          ]
        },
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.DIFY_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        }
      },
      "id": "executeWorkflow",
      "name": "Execute Dify Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "url": "=https://api.dify.ai/datasets/{{ $node.trigger.json.dataset_id }}/documents",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "file",
              "value": "={{ $node.trigger.json.file }}"
            },
            {
              "name": "metadata",
              "value": "={{ $node.trigger.json.metadata }}"
            }
          ]
        },
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.DIFY_API_KEY }}"
            }
          ]
        }
      },
      "id": "ingestDocument",
      "name": "Ingest Document",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        250,
        450
      ]
    },
    {
      "parameters": {
        "url": "=https://api.dify.ai/datasets/{{ $node.trigger.json.dataset_id }}/retrieve",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "query",
              "value": "={{ $node.trigger.json.query }}"
            },
            {
              "name": "limit",
              "value": "=10"
            }
          ]
        },
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.DIFY_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        }
      },
      "id": "retrieveDocuments",
      "name": "Retrieve Documents (RAG)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        250,
        600
      ]
    },
    {
      "parameters": {
        "url": "=https://api.dify.ai/chat-messages",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "app_id",
              "value": "={{ $node.trigger.json.app_id }}"
            },
            {
              "name": "inputs",
              "value": "={{ $node.trigger.json.message_inputs }}"
            },
            {
              "name": "query",
              "value": "={{ $node.trigger.json.user_query }}"
            }
          ]
        },
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.DIFY_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        }
      },
      "id": "sendChatMessage",
      "name": "Send Chat Message",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "url": "=https://api.dify.ai/workflows",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "name",
              "value": "={{ $node.trigger.json.workflow_name }}"
            },
            {
              "name": "description",
              "value": "={{ $node.trigger.json.workflow_description }}"
            },
            {
              "name": "nodes",
              "value": "={{ $node.trigger.json.workflow_nodes }}"
            }
          ]
        },
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.DIFY_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        }
      },
      "id": "createWorkflow",
      "name": "Create Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        150
      ]
    },
    {
      "parameters": {
        "url": "=https://api.dify.ai/agents",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "app_id",
              "value": "={{ $node.trigger.json.app_id }}"
            },
            {
              "name": "tools",
              "value": "={{ $node.trigger.json.tools }}"
            },
            {
              "name": "mode",
              "value": "={{ $node.trigger.json.agent_mode }}"
            }
          ]
        },
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.DIFY_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        }
      },
      "id": "configureAgent",
      "name": "Configure Agent",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        600
      ]
    },
    {
      "parameters": {
        "url": "=https://api.dify.ai/logs",
        "method": "GET",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.DIFY_API_KEY }}"
            }
          ]
        }
      },
      "id": "fetchLogs",
      "name": "Fetch Application Logs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "url": "=https://api.dify.ai/datasets",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "name",
              "value": "={{ $node.trigger.json.dataset_name }}"
            },
            {
              "name": "description",
              "value": "={{ $node.trigger.json.dataset_description }}"
            }
          ]
        },
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.DIFY_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        }
      },
      "id": "createDataset",
      "name": "Create Dataset",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        450
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "1",
              "name": "workflow_status",
              "value": "={{ $node.executeWorkflow.json.status }}"
            },
            {
              "id": "2",
              "name": "execution_result",
              "value": "={{ $node.executeWorkflow.json.result }}"
            },
            {
              "id": "3",
              "name": "document_count",
              "value": "={{ $node.retrieveDocuments.json.documents.length }}"
            },
            {
              "id": "4",
              "name": "agent_status",
              "value": "={{ $node.configureAgent.json.status }}"
            }
          ]
        }
      },
      "id": "processResults",
      "name": "Process Results",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.3,
      "position": [
        800,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "id": "1",
              "operator": {
                "name": "filter.operator.equals",
                "value": "equals"
              },
              "leftValue": "={{ $node.processResults.json.workflow_status }}",
              "rightValue": "success"
            }
          ]
        }
      },
      "id": "validateResults",
      "name": "Validate Workflow Status",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        950,
        300
      ]
    },
    {
      "parameters": {
        "url": "=https://api.dify.ai/webhooks/{{ $node.trigger.json.callback_url }}",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "status",
              "value": "=complete"
            },
            {
              "name": "data",
              "value": "={{ $node.processResults.json }}"
            }
          ]
        }
      },
      "id": "sendCallback",
      "name": "Send Callback",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1100,
        200
      ]
    }
  ],
  "connections": {
    "trigger": {
      "main": [
        [
          {
            "node": "executeWorkflow",
            "type": "main",
            "index": 0
          },
          {
            "node": "ingestDocument",
            "type": "main",
            "index": 0
          },
          {
            "node": "createWorkflow",
            "type": "main",
            "index": 0
          },
          {
            "node": "createDataset",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "executeWorkflow": {
      "main": [
        [
          {
            "node": "sendChatMessage",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "ingestDocument": {
      "main": [
        [
          {
            "node": "retrieveDocuments",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "retrieveDocuments": {
      "main": [
        [
          {
            "node": "processResults",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "sendChatMessage": {
      "main": [
        [
          {
            "node": "fetchLogs",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "createWorkflow": {
      "main": [
        [
          {
            "node": "processResults",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "configureAgent": {
      "main": [
        [
          {
            "node": "processResults",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetchLogs": {
      "main": [
        [
          {
            "node": "processResults",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "createDataset": {
      "main": [
        [
          {
            "node": "ingestDocument",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "processResults": {
      "main": [
        [
          {
            "node": "validateResults",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "validateResults": {
      "main": [
        [
          {
            "node": "sendCallback",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "sendCallback",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  }
}