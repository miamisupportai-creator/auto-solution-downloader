{
  "name": "Dify LLM Application Development Platform",
  "nodes": [
    {
      "parameters": {},
      "id": "webhook-trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "dify-webhook"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=http://localhost:3000/api/workflows/execute",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.DIFY_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "inputs",
              "value": "={{ $json.payload }}"
            }
          ]
        }
      },
      "id": "call-dify-api",
      "name": "Call Dify API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [450, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "workflow_id",
              "name": "workflow_id",
              "type": "string",
              "value": "={{ $json.data.workflow_id }}"
            },
            {
              "id": "execution_status",
              "name": "execution_status",
              "type": "string",
              "value": "={{ $json.data.status }}"
            },
            {
              "id": "outputs",
              "name": "outputs",
              "type": "object",
              "value": "={{ $json.data.outputs }}"
            }
          ]
        }
      },
      "id": "transform-response",
      "name": "Transform Response",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [650, 300]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "id": "condition_1",
              "name": "Check Status",
              "type": "string",
              "operator": {
                "name": "filter.operator.equals",
                "type": "string",
                "value": "equals"
              },
              "value": "completed",
              "leftValue": "={{ $json.execution_status }}"
            }
          ]
        }
      },
      "id": "check-execution-status",
      "name": "Check Execution Status",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [850, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=http://localhost:3000/api/logs/save",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.DIFY_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "workflow_id",
              "value": "={{ $json.workflow_id }}"
            },
            {
              "name": "status",
              "value": "={{ $json.execution_status }}"
            },
            {
              "name": "outputs",
              "value": "={{ $json.outputs }}"
            },
            {
              "name": "timestamp",
              "value": "={{ new Date().toISOString() }}"
            }
          ]
        }
      },
      "id": "log-workflow-execution",
      "name": "Log Workflow Execution",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1050, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=http://localhost:3000/api/error-handler",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.DIFY_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "error",
              "value": "={{ $json.execution_status }}"
            },
            {
              "name": "workflow_id",
              "value": "={{ $json.workflow_id }}"
            }
          ]
        }
      },
      "id": "handle-execution-error",
      "name": "Handle Execution Error",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1050, 400]
    },
    {
      "parameters": {
        "respondWithData": true
      },
      "id": "webhook-response-success",
      "name": "Webhook Response Success",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1250, 200]
    },
    {
      "parameters": {
        "respondWithData": true
      },
      "id": "webhook-response-error",
      "name": "Webhook Response Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1250, 400]
    }
  ],
  "connections": {
    "webhook-trigger": {
      "main": [
        [
          {
            "node": "call-dify-api",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "call-dify-api": {
      "main": [
        [
          {
            "node": "transform-response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "transform-response": {
      "main": [
        [
          {
            "node": "check-execution-status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check-execution-status": {
      "main": [
        [
          {
            "node": "log-workflow-execution",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "handle-execution-error",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "log-workflow-execution": {
      "main": [
        [
          {
            "node": "webhook-response-success",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "handle-execution-error": {
      "main": [
        [
          {
            "node": "webhook-response-error",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1"
  }
}