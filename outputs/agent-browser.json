{
  "name": "agent-browser CI/CD Automation",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": [
          {
            "mode": "everyDay",
            "hour": 0,
            "minute": 0
          }
        ]
      },
      "id": "Schedule_Trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        50,
        250
      ]
    },
    {
      "parameters": {
        "httpMethod": "GET",
        "url": "https://registry.npmjs.org/agent-browser",
        "options": {}
      },
      "id": "Check_NPM_Version",
      "name": "Check NPM Version",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        250,
        250
      ]
    },
    {
      "parameters": {
        "code": "const npmData = $input.all()[0].json.json;\nconst npmVersion = npmData['dist-tags'].latest;\nconst localVersion = $env.PKG_VERSION || '0.0.0';\nreturn {\n  npmVersion,\n  localVersion,\n  shouldRelease: npmVersion !== localVersion,\n  needsGithubRelease: true\n};"
      },
      "id": "Compare_Versions",
      "name": "Compare Versions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        450,
        250
      ]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "value1": "{{ $json.shouldRelease }}",
              "operator": "equals",
              "value2": true
            }
          ],
          "combinator": "and"
        }
      },
      "id": "Should_Release_Decision",
      "name": "Should Release Decision",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        650,
        250
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/actions/workflows/release.yml/dispatches",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "token {{ $env.GITHUB_TOKEN }}"
            },
            {
              "name": "X-GitHub-Api-Version",
              "value": "2022-11-28"
            }
          ]
        },
        "sendBody": true,
        "bodyParametersUi": "json",
        "body": "{\n  \"ref\": \"main\"\n}",
        "options": {}
      },
      "id": "Trigger_Release_Workflow",
      "name": "Trigger Release Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        850,
        100
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/actions/workflows/ci.yml/dispatches",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "token {{ $env.GITHUB_TOKEN }}"
            },
            {
              "name": "X-GitHub-Api-Version",
              "value": "2022-11-28"
            }
          ]
        },
        "sendBody": true,
        "bodyParametersUi": "json",
        "body": "{\n  \"ref\": \"main\"\n}",
        "options": {}
      },
      "id": "Trigger_CI_Workflow",
      "name": "Trigger CI Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        850,
        250
      ]
    },
    {
      "parameters": {
        "code": "return {\n  status: 'Release workflow triggered',\n  timestamp: new Date().toISOString()\n};"
      },
      "id": "Release_Success",
      "name": "Release Success",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1050,
        100
      ]
    },
    {
      "parameters": {
        "code": "return {\n  status: 'No release needed',\n  reason: 'Version unchanged on npm',\n  timestamp: new Date().toISOString()\n};"
      },
      "id": "No_Release_Needed",
      "name": "No Release Needed",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        850,
        400
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/releases/tags/v{{ $json.localVersion }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "token {{ $env.GITHUB_TOKEN }}"
            },
            {
              "name": "X-GitHub-Api-Version",
              "value": "2022-11-28"
            }
          ]
        },
        "options": {}
      },
      "id": "Check_GitHub_Release",
      "name": "Check GitHub Release",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        400
      ]
    },
    {
      "parameters": {
        "code": "const releaseExists = $input.all().some(node => node.json?.id);\nreturn {\n  releaseExists\n};"
      },
      "id": "Parse_Release_Check",
      "name": "Parse Release Check",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        650,
        400
      ]
    }
  ],
  "connections": {
    "Schedule_Trigger": {
      "main": [
        [
          {
            "node": "Check_NPM_Version",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check_NPM_Version": {
      "main": [
        [
          {
            "node": "Compare_Versions",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Compare_Versions": {
      "main": [
        [
          {
            "node": "Should_Release_Decision",
            "type": "main",
            "index": 0
          },
          {
            "node": "Check_GitHub_Release",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Should_Release_Decision": {
      "main": [
        [
          {
            "node": "Trigger_Release_Workflow",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "No_Release_Needed",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Trigger_Release_Workflow": {
      "main": [
        [
          {
            "node": "Release_Success",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check_GitHub_Release": {
      "main": [
        [
          {
            "node": "Parse_Release_Check",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse_Release_Check": {
      "main": [
        [
          {
            "node": "Trigger_CI_Workflow",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "pinData": {}
}