{
  "name": "agent-browser Benchmark & Release Automation",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": {
          "item": [
            {
              "mode": "everyDay",
              "hour": 2,
              "minute": 0
            }
          ]
        }
      },
      "id": "trigger-schedule",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [50, 100]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/releases/latest",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth"
      },
      "id": "check-latest-release",
      "name": "Check Latest Release",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [250, 100]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://registry.npmjs.org/agent-browser"
      },
      "id": "check-npm-version",
      "name": "Check NPM Version",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [450, 100]
    },
    {
      "parameters": {
        "functionCode": "const npmData = $input.all();\nconst npmVersion = npmData[0].json['dist-tags'].latest;\nconst latestRelease = $input.all()[1].json;\nconst releaseVersion = latestRelease.tag_name.replace('v', '');\n\nreturn {\n  npmVersion,\n  releaseVersion,\n  needsUpdate: npmVersion !== releaseVersion,\n  needsGithubRelease: latestRelease.assets.length === 0\n};"
      },
      "id": "compare-versions",
      "name": "Compare Versions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 100]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.needsUpdate }}",
              "operation": "equals",
              "value2": true
            }
          ]
        }
      },
      "id": "decide-publish",
      "name": "Should Publish?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [850, 100]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.github.com/repos/vercel-labs/agent-browser",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth"
      },
      "id": "get-repo-info",
      "name": "Get Repository Info",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1050, 50]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/actions/workflows/release.yml/dispatches",
        "body": "{\n  \"ref\": \"main\"\n}",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth"
      },
      "id": "trigger-release-workflow",
      "name": "Trigger Release Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1050, 150]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.github.com/repos/vercel-labs/agent-browser/actions/runs?event=workflow_dispatch&status=in_progress",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth"
      },
      "id": "poll-workflow-status",
      "name": "Poll Workflow Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1250, 150]
    },
    {
      "parameters": {
        "functionCode": "const runs = $input.all()[0].json.workflow_runs;\nif (!runs || runs.length === 0) {\n  return { status: 'pending', message: 'Workflow not yet started' };\n}\n\nconst latestRun = runs[0];\nreturn {\n  status: latestRun.status,\n  conclusion: latestRun.conclusion,\n  url: latestRun.html_url,\n  isComplete: latestRun.status === 'completed'\n};"
      },
      "id": "parse-workflow-status",
      "name": "Parse Workflow Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1450, 150]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.isComplete }}",
              "operation": "equals",
              "value2": false
            }
          ]
        }
      },
      "id": "check-workflow-complete",
      "name": "Workflow Complete?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1650, 150]
    },
    {
      "parameters": {
        "delayType": "seconds",
        "secondsToWait": 30
      },
      "id": "wait-for-workflow",
      "name": "Wait 30 Seconds",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [1850, 150]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK",
        "body": "{\n  \"text\": \"agent-browser Release Complete\",\n  \"blocks\": [\n    {\n      \"type\": \"section\",\n      \"text\": {\n        \"type\": \"mrkdwn\",\n        \"text\": \"✅ *agent-browser v{{ $json.npmVersion }}* published to npm\\n*Binaries:* 7 platforms built and released\"\n      }\n    },\n    {\n      \"type\": \"actions\",\n      \"elements\": [\n        {\n          \"type\": \"button\",\n          \"text\": {\n            \"type\": \"plain_text\",\n            \"text\": \"View Release\"\n          },\n          \"url\": \"https://github.com/vercel-labs/agent-browser/releases/latest\"\n        }\n      ]\n    }\n  ]\n}"
      },
      "id": "notify-release-success",
      "name": "Notify Release Success",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2050, 100]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK",
        "body": "{\n  \"text\": \"⚠️ agent-browser Release Failed\",\n  \"attachments\": [\n    {\n      \"color\": \"danger\",\n      \"text\": \"Workflow status: {{ $json.conclusion }}\\nCheck: {{ $json.url }}\"\n    }\n  ]\n}"
      },
      "id": "notify-release-failure",
      "name": "Notify Release Failure",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2050, 200]
    }
  ],
  "connections": {
    "trigger-schedule": {
      "main": [
        [
          {
            "node": "check-latest-release",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check-latest-release": {
      "main": [
        [
          {
            "node": "check-npm-version",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check-npm-version": {
      "main": [
        [
          {
            "node": "compare-versions",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "compare-versions": {
      "main": [
        [
          {
            "node": "decide-publish",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "decide-publish": {
      "main": [
        [
          {
            "node": "get-repo-info",
            "type": "main",
            "index": 0
          },
          {
            "node": "trigger-release-workflow",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "trigger-release-workflow": {
      "main": [
        [
          {
            "node": "poll-workflow-status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "poll-workflow-status": {
      "main": [
        [
          {
            "node": "parse-workflow-status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "parse-workflow-status": {
      "main": [
        [
          {
            "node": "check-workflow-complete",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check-workflow-complete": {
      "main": [
        [
          {
            "node": "wait-for-workflow",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "notify-release-success",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "wait-for-workflow": {
      "main": [
        [
          {
            "node": "poll-workflow-status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "notify-release-success": {
      "main": [
        []
      ]
    },
    "notify-release-failure": {
      "main": [
        []
      ]
    }
  },
  "active": true,
  "settings": {
    "errorWorkflow": "",
    "saveExecutionProgress": true,
    "saveManualExecutions": true,
    "timezone": "UTC"
  },
  "staticData": null,
  "versionId": "1"
}