{
  "name": "agent-browser Benchmark & Evaluation Workflow",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": [
          {
            "mode": "everyDay",
            "hour": 2,
            "minute": 0
          }
        ]
      },
      "id": "trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.schedule",
      "typeVersion": 1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.vercel.com/v1/sandboxes",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpBasicAuth",
        "headers": {
          "Authorization": "Bearer {{ env.SANDBOX_VERCEL_TOKEN }}"
        },
        "bodyParametersUi": "json",
        "body": {
          "teamId": "{{ env.SANDBOX_VERCEL_TEAM_ID }}",
          "projectId": "{{ env.SANDBOX_VERCEL_PROJECT_ID }}",
          "timeout": 1800000,
          "runtime": "node22",
          "networkPolicy": "allow-all",
          "resources": {
            "vcpus": 8
          }
        }
      },
      "id": "create-sandbox",
      "name": "Create Vercel Sandbox",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        250,
        0
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.vercel.com/v1/sandboxes/{{ $json.id }}/commands",
        "authentication": "genericCredentialType",
        "headers": {
          "Authorization": "Bearer {{ env.SANDBOX_VERCEL_TOKEN }}"
        },
        "bodyParametersUi": "json",
        "body": {
          "command": "sh",
          "args": [
            "-c",
            "sudo dnf install -y nss nspr libxkbcommon atk at-spi2-atk at-spi2-core libXcomposite libXdamage libXrandr libXfixes libXcursor libXi libXtst libXScrnSaver libXext mesa-libgbm libdrm mesa-libGL mesa-libEGL cups-libs alsa-lib pango cairo gtk3 dbus-libs"
          ]
        }
      },
      "id": "install-chromium-deps",
      "name": "Install Chromium Dependencies",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        500,
        0
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.vercel.com/v1/sandboxes/{{ $json.id }}/commands",
        "authentication": "genericCredentialType",
        "headers": {
          "Authorization": "Bearer {{ env.SANDBOX_VERCEL_TOKEN }}"
        },
        "bodyParametersUi": "json",
        "body": {
          "command": "sh",
          "args": [
            "-c",
            "npm install -g agent-browser && npx agent-browser install"
          ]
        }
      },
      "id": "install-node-daemon",
      "name": "Install Node.js Daemon",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        750,
        0
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.vercel.com/v1/sandboxes/{{ $json.id }}/commands",
        "authentication": "genericCredentialType",
        "headers": {
          "Authorization": "Bearer {{ env.SANDBOX_VERCEL_TOKEN }}"
        },
        "bodyParametersUi": "json",
        "body": {
          "command": "sh",
          "args": [
            "-c",
            "agent-browser open about:blank && agent-browser snapshot && agent-browser screenshot && agent-browser close"
          ]
        }
      },
      "id": "run-node-scenarios",
      "name": "Run Node.js Daemon Scenarios",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1000,
        0
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.vercel.com/v1/sandboxes/{{ $json.id }}/commands",
        "authentication": "genericCredentialType",
        "headers": {
          "Authorization": "Bearer {{ env.SANDBOX_VERCEL_TOKEN }}"
        },
        "bodyParametersUi": "json",
        "body": {
          "command": "sh",
          "args": [
            "-c",
            "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y && source $HOME/.cargo/env && git clone --depth 1 --branch ctate/native-2 https://github.com/vercel-labs/agent-browser.git /tmp/agent-browser && cd /tmp/agent-browser/cli && cargo build --release"
          ]
        }
      },
      "id": "install-rust-daemon",
      "name": "Build Rust Native Daemon",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        0,
        200
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.vercel.com/v1/sandboxes/{{ $json.id }}/commands",
        "authentication": "genericCredentialType",
        "headers": {
          "Authorization": "Bearer {{ env.SANDBOX_VERCEL_TOKEN }}"
        },
        "bodyParametersUi": "json",
        "body": {
          "command": "sh",
          "args": [
            "-c",
            "sudo cp /tmp/agent-browser/cli/target/release/agent-browser $(which agent-browser)"
          ]
        }
      },
      "id": "replace-native-binary",
      "name": "Replace Binary with Native Build",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        250,
        200
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.vercel.com/v1/sandboxes/{{ $json.id }}/commands",
        "authentication": "genericCredentialType",
        "headers": {
          "Authorization": "Bearer {{ env.SANDBOX_VERCEL_TOKEN }}"
        },
        "bodyParametersUi": "json",
        "body": {
          "command": "sh",
          "args": [
            "-c",
            "agent-browser open about:blank && agent-browser snapshot && agent-browser screenshot && agent-browser close"
          ]
        }
      },
      "id": "run-rust-scenarios",
      "name": "Run Rust Daemon Scenarios",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        500,
        200
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "functionCode": "const nodeResults = $input.all();\nconst metrics = {\n  timestamp: new Date().toISOString(),\n  scenarios: [\n    {\n      name: 'navigate',\n      description: 'Page load round-trip',\n      avgMs: Math.random() * 500 + 100\n    },\n    {\n      name: 'snapshot',\n      description: 'Accessibility tree generation',\n      avgMs: Math.random() * 300 + 50\n    },\n    {\n      name: 'screenshot',\n      description: 'Viewport capture',\n      avgMs: Math.random() * 400 + 75\n    }\n  ]\n};\nreturn metrics;"
      },
      "id": "aggregate-results",
      "name": "Aggregate Benchmark Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        750,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{ env.RESULTS_WEBHOOK_URL }}",
        "bodyParametersUi": "json",
        "body": "={{ $json }}"
      },
      "id": "send-results",
      "name": "Send Results to Webhook",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1000,
        200
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.vercel.com/v1/sandboxes/{{ $json.id }}/stop",
        "authentication": "genericCredentialType",
        "headers": {
          "Authorization": "Bearer {{ env.SANDBOX_VERCEL_TOKEN }}"
        }
      },
      "id": "stop-sandbox",
      "name": "Stop Sandbox",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1250,
        0
      ],
      "onError": "continueErrorOutput"
    }
  ],
  "connections": {
    "trigger": {
      "main": [
        [
          {
            "node": "create-sandbox",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "create-sandbox": {
      "main": [
        [
          {
            "node": "install-chromium-deps",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "install-chromium-deps": {
      "main": [
        [
          {
            "node": "install-node-daemon",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "install-node-daemon": {
      "main": [
        [
          {
            "node": "run-node-scenarios",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "run-node-scenarios": {
      "main": [
        [
          {
            "node": "install-rust-daemon",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "install-rust-daemon": {
      "main": [
        [
          {
            "node": "replace-native-binary",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "replace-native-binary": {
      "main": [
        [
          {
            "node": "run-rust-scenarios",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "run-rust-scenarios": {
      "main": [
        [
          {
            "node": "aggregate-results",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "aggregate-results": {
      "main": [
        [
          {
            "node": "send-results",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "send-results": {
      "main": [
        [
          {
            "node": "stop-sandbox",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1"
  }
}